@model PROmaderas.UI.Models.CrearParametroViewModel
@{
    ViewData["Title"] = "Nuevo parámetro";
}

<partial name="_TemaOscuro" />

<div class="container mt-4" style="max-width:720px">
    <h2 class="mb-4"><i class="bi bi-plus-circle me-2" style="color:#c9a03c"></i>Nuevo parámetro</h2>

    <partial name="_ConvencionUnidades" />

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="NombreParametro" class="form-label fw-semibold"></label>
                    <input asp-for="NombreParametro" class="form-control"
                           placeholder="Ej. PorcentajeCCSS" />
                    <span asp-validation-for="NombreParametro" class="text-danger"></span>
                    <div class="form-text">
                        Sin espacios: es la clave que consume el código, no una etiqueta.
                        El sufijo define la unidad (ver convención arriba).
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Valor" class="form-label fw-semibold">Valor</label>
                    <input asp-for="Valor" type="number" step="0.0001" min="0" class="form-control" />
                    <span asp-validation-for="Valor" class="text-danger"></span>
                    <div class="form-text">Hasta 4 decimales.</div>
                </div>

                <div class="mb-4">
                    <label asp-for="FechaInicio" class="form-label fw-semibold"></label>
                    <input asp-for="FechaInicio" type="date" class="form-control" />
                    <span asp-validation-for="FechaInicio" class="text-danger"></span>
                    <div class="form-text">
                        Es la <strong>vigencia</strong> del parámetro (desde cuándo rige ese valor),
                        no la fecha de hoy. Queda abierta hasta que una versión nueva la cierre.
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning fw-bold px-4">
                        <i class="bi bi-floppy me-1"></i>Guardar
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-x-lg me-1"></i>Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
