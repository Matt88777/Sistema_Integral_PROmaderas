@model PROmaderas.Abstracciones.Models.TipoTarimaCrearDTO

@{
    ViewData["Title"] = "Editar Tipo de Tarima";
    int productoId = ViewBag.ProductoId != null ? (int)ViewBag.ProductoId : 0;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(201,168,76,0.25);border-radius:10px;padding:2rem;">
                <h4 class="mb-4" style="color:#c9a84c;">
                    <i class="bi bi-pencil-square me-2"></i>Editar Tipo de Tarima
                </h4>

                <form asp-action="Edit" asp-route-id="@productoId" method="post">
                    <div asp-validation-summary="ModelOnly" class="mb-3" style="background:rgba(220,53,69,0.15);border:1px solid rgba(220,53,69,0.4);border-radius:6px;padding:0.75rem;color:#f87171;"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Codigo" class="form-label" style="color:rgba(255,255,255,0.75)"></label>
                            <input asp-for="Codigo" class="form-control" style="background:rgba(255,255,255,0.07);border:1px solid rgba(201,168,76,0.3);color:#fff;" />
                            <span asp-validation-for="Codigo" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Medida" class="form-label" style="color:rgba(255,255,255,0.75)"></label>
                            <input asp-for="Medida" class="form-control" style="background:rgba(255,255,255,0.07);border:1px solid rgba(201,168,76,0.3);color:#fff;" />
                            <span asp-validation-for="Medida" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Nombre" class="form-label" style="color:rgba(255,255,255,0.75)"></label>
                            <input asp-for="Nombre" class="form-control" style="background:rgba(255,255,255,0.07);border:1px solid rgba(201,168,76,0.3);color:#fff;" />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Descripcion" class="form-label" style="color:rgba(255,255,255,0.75)"></label>
                            <textarea asp-for="Descripcion" class="form-control" rows="3" style="background:rgba(255,255,255,0.07);border:1px solid rgba(201,168,76,0.3);color:#fff;"></textarea>
                            <span asp-validation-for="Descripcion" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PrecioUnitario" class="form-label" style="color:rgba(255,255,255,0.75)"></label>
                            <input asp-for="PrecioUnitario" class="form-control" type="number" step="0.01" style="background:rgba(255,255,255,0.07);border:1px solid rgba(201,168,76,0.3);color:#fff;" />
                            <span asp-validation-for="PrecioUnitario" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="StockMinimo" class="form-label" style="color:rgba(255,255,255,0.75)"></label>
                            <input asp-for="StockMinimo" class="form-control" type="number" style="background:rgba(255,255,255,0.07);border:1px solid rgba(201,168,76,0.3);color:#fff;" />
                            <span asp-validation-for="StockMinimo" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <div class="form-check">
                                <input asp-for="Activo" class="form-check-input" type="checkbox" />
                                <label asp-for="Activo" class="form-check-label" style="color:rgba(255,255,255,0.75)"></label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 justify-content-end mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                        <button type="submit" class="btn btn-warning fw-bold">
                            <i class="bi bi-floppy me-1"></i>Guardar Cambios
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}