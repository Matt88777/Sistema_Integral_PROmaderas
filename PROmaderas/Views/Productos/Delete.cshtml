@model PROmaderas.Abstracciones.Models.ProductoAD

@{
    ViewData["Title"] = "Eliminar Producto";
}
@if (!User.IsInRole("Administrador"))
{
    <div class="alert alert-danger mt-4">
        No tienes permisos para eliminar productos.
    </div>
    return;
}
<div class="container mt-4">
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <h2 class="text-danger">Eliminar Producto</h2>
            <hr />

            <div class="alert alert-warning" role="alert">
                <h5 class="alert-heading">¿Está seguro que desea eliminar este producto?</h5>
                <p>Esta acción marcará el producto como inactivo.</p>
            </div>

            <div class="card">
                <div class="card-body">
                    <div class="text-center mb-3">
                        <img src="@Model.ImagenUrl" alt="@Model.Nombre" style="max-width: 200px;" class="img-thumbnail" />
                    </div>

                    <dl class="row">
                        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Nombre)</dt>
                        <dd class="col-sm-8">@Model.Nombre</dd>

                        <dt class="col-sm-4">Categoría</dt>
                        <dd class="col-sm-8">@Model.Categoria?.Nombre</dd>

                        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Precio)</dt>
                        <dd class="col-sm-8">₡@Model.Precio.ToString("N2")</dd>

                        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Stock)</dt>
                        <dd class="col-sm-8">@Model.Stock</dd>
                    </dl>
                </div>
            </div>

            <form asp-action="Delete" method="post" class="mt-3">
                <input type="hidden" asp-for="Id" />
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-danger">Sí, Eliminar</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>