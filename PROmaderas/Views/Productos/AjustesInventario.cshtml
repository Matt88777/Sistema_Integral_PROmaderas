@model PROmaderas.UI.Models.AjusteInventarioViewModel
@using PROmaderas.Abstracciones.Catalogos

@{
    ViewData["Title"] = "Ajustes de Inventario";
}

<div class="container mt-4">
    <div class="row mb-3 align-items-center">
        <div class="col">
            <h2>
                <i class="bi bi-pencil-square me-2" style="color:#c9a03c"></i>
                Ajustes de inventario
            </h2>
            <p class="text-muted mb-0">
                Registre correcciones aprobadas con motivo y autorización para mantener el inventario físico alineado con el sistema.
            </p>
        </div>
    </div>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success">
            <i class="bi bi-check-circle me-1"></i>
            @TempData["Mensaje"]
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-5">
            <form asp-action="AjustesInventario" method="post" class="card shadow-sm">
                @Html.AntiForgeryToken()

                <div class="card-header bg-dark text-white">
                    <i class="bi bi-clipboard-plus me-1"></i>
                    Registrar ajuste
                </div>

                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Ajuste.IdTipoTarima" class="form-label fw-semibold"></label>
                        <select asp-for="Ajuste.IdTipoTarima" class="form-select">
                            <option value="">Seleccione un tipo de tarima</option>
                            @foreach (var tipo in Model.TiposTarima)
                            {
                                <option value="@tipo.Id">@tipo.Codigo - @tipo.Nombre (@tipo.Medida)</option>
                            }
                        </select>
                        <span asp-validation-for="Ajuste.IdTipoTarima" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Ajuste.TipoAjuste" class="form-label fw-semibold"></label>
                        <select asp-for="Ajuste.TipoAjuste" class="form-select">
                            <option value="@TiposMovimientoInventario.AjusteEntrada">Ajuste de entrada</option>
                            <option value="@TiposMovimientoInventario.AjusteSalida">Ajuste de salida</option>
                        </select>
                        <span asp-validation-for="Ajuste.TipoAjuste" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Ajuste.Cantidad" class="form-label fw-semibold"></label>
                        <input asp-for="Ajuste.Cantidad" class="form-control" type="number" min="1" />
                        <span asp-validation-for="Ajuste.Cantidad" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Ajuste.Motivo" class="form-label fw-semibold"></label>
                        <textarea asp-for="Ajuste.Motivo" class="form-control" rows="3" placeholder="Ejemplo: conteo físico, tarimas dañadas, corrección por despacho, etc."></textarea>
                        <span asp-validation-for="Ajuste.Motivo" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Ajuste.Autorizacion" class="form-label fw-semibold"></label>
                        <input asp-for="Ajuste.Autorizacion" class="form-control" placeholder="Nombre, código o referencia de aprobación" />
                        <span asp-validation-for="Ajuste.Autorizacion" class="text-danger"></span>
                        <small class="text-muted">
                            Sin autorización, el sistema bloqueará el registro del ajuste.
                        </small>
                    </div>
                </div>

                <div class="card-footer d-flex gap-2">
                    <button type="submit" class="btn btn-warning fw-bold">
                        <i class="bi bi-save me-1"></i>Guardar ajuste
                    </button>
                    <a asp-action="Inventario" class="btn btn-outline-secondary">
                        Consultar inventario
                    </a>
                </div>
            </form>
        </div>

        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white">
                    <i class="bi bi-box-seam me-1"></i>
                    Existencias actuales de referencia
                </div>

                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Código</th>
                                <th>Tipo de tarima</th>
                                <th class="text-end">Disponible</th>
                                <th class="text-end">Stock mínimo</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Existencias.Any())
                            {
                                foreach (var item in Model.Existencias)
                                {
                                    <tr>
                                        <td>@item.Codigo</td>
                                        <td>
                                            <span class="fw-semibold">@item.TipoTarima</span><br />
                                            <small class="text-muted">@item.Medida</small>
                                        </td>
                                        <td class="text-end fw-bold">@item.StockActual</td>
                                        <td class="text-end">@item.StockMinimo</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-3">
                                        No hay información de inventario para mostrar.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i>Volver a productos
        </a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}