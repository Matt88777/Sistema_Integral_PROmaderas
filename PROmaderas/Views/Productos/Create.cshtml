@model PROmaderas.Abstracciones.Models.TipoTarimaCrearDTO

@{
    ViewData["Title"] = "Registrar tipo de tarima";
}

<div class="container mt-4">
    <div class="row mb-3 align-items-center">
        <div class="col">
            <h2>
                <i class="bi bi-box-seam me-2" style="color:#c9a03c"></i>
                Registrar tipo de tarima
            </h2>
            <p class="text-muted mb-0">
                Complete la información para ampliar el catálogo de productos.
            </p>
        </div>
    </div>

    <div class="card shadow-sm" style="border-color:#c9a03c;">
        <div class="card-header fw-bold" style="background-color:#c9a03c;color:#1a1a1a;">
            <i class="bi bi-plus-circle me-1"></i>Nuevo tipo de tarima
        </div>

        <div class="card-body">
            <form asp-action="Create" method="post" class="row g-3">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="col-md-6">
                    <label asp-for="Codigo" class="form-label fw-semibold"></label>
                    <input asp-for="Codigo"
                           class="form-control"
                           placeholder="Ejemplo: TAR-40X48-USA" />
                    <span asp-validation-for="Codigo" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Nombre" class="form-label fw-semibold"></label>
                    <input asp-for="Nombre"
                           class="form-control"
                           placeholder="Ejemplo: Tarima estándar USA" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Medida" class="form-label fw-semibold"></label>
                    <input asp-for="Medida"
                           class="form-control"
                           placeholder="Ejemplo: 40x48" />
                    <span asp-validation-for="Medida" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="PrecioUnitario" class="form-label fw-semibold"></label>
                    <input asp-for="PrecioUnitario"
                           class="form-control"
                           type="number"
                           step="0.01"
                           min="0.01"
                           placeholder="Ejemplo: 8500" />
                    <span asp-validation-for="PrecioUnitario" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="StockMinimo" class="form-label fw-semibold"></label>
                    <input asp-for="StockMinimo"
                           class="form-control"
                           type="number"
                           min="0"
                           placeholder="Ejemplo: 10" />
                    <span asp-validation-for="StockMinimo" class="text-danger"></span>
                </div>

                <div class="col-md-6 d-flex align-items-end">
                    <div class="form-check">
                        <input asp-for="Activo" class="form-check-input" />
                        <label asp-for="Activo" class="form-check-label fw-semibold"></label>
                    </div>
                </div>

                <div class="col-12">
                    <label asp-for="Descripcion" class="form-label fw-semibold"></label>
                    <textarea asp-for="Descripcion"
                              class="form-control"
                              rows="3"
                              maxlength="250"
                              placeholder="Descripción opcional del tipo de tarima"></textarea>
                    <span asp-validation-for="Descripcion" class="text-danger"></span>
                </div>

                <div class="col-12 d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Cancelar
                    </a>

                    <button type="submit" class="btn btn-warning fw-bold">
                        <i class="bi bi-save me-1"></i>Guardar tipo de tarima
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}