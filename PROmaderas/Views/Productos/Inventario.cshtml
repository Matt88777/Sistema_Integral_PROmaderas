@model PROmaderas.UI.Models.InventarioConsultaViewModel
@using PROmaderas.Abstracciones.Models

@{
    ViewData["Title"] = "Consulta de Inventario";

    var tiposEntrada = TiposMovimientoInventario.TiposEntrada.ToList();
    var tiposSalida = TiposMovimientoInventario.TiposSalida.ToList();
}

<div class="container mt-4">
    <div class="row mb-3 align-items-center">
        <div class="col">
            <h2><i class="bi bi-boxes me-2" style="color:#c9a03c"></i>Consulta de Inventario</h2>
            <p class="text-muted mb-0">Existencias actuales e historial de movimientos por tipo de tarima.</p>
        </div>
        <div class="col-auto">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Volver a productos
            </a>
        </div>
    </div>

    <form method="get" asp-action="Inventario" class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Tipo de tarima</label>
                    <select asp-for="IdTipoTarima" class="form-select">
                        <option value="">Todos los tipos de tarima</option>
                        @foreach (var tipo in Model.TiposTarima)
                        {
                            <option value="@tipo.Id" selected="@(Model.IdTipoTarima == tipo.Id)">
                                @tipo.Codigo - @tipo.Nombre (@tipo.Medida)
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-auto d-flex gap-2">
                    <button type="submit" class="btn btn-warning fw-bold px-4">
                        <i class="bi bi-search me-1"></i>Consultar
                    </button>
                    <a asp-action="Inventario" class="btn btn-outline-secondary">Limpiar</a>
                </div>
            </div>
        </div>
    </form>

    @if (!Model.Existencias.Any() && !Model.Movimientos.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-1"></i>No hay información para mostrar según la consulta realizada.
        </div>
    }
    else
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-dark text-white">
                <i class="bi bi-clipboard-data me-1"></i>Existencias actuales
            </div>
            <div class="card-body p-0">
                @if (!Model.Existencias.Any())
                {
                    <div class="p-3 text-muted">No hay existencias registradas.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th>Código</th>
                                    <th>Tipo de tarima</th>
                                    <th>Medida</th>
                                    <th class="text-end">Entradas</th>
                                    <th class="text-end">Salidas</th>
                                    <th class="text-end">Disponible</th>
                                    <th class="text-end">Stock mínimo</th>
                                    <th>Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Existencias)
                                {
                                    <tr>
                                        <td class="fw-semibold">@item.Codigo</td>
                                        <td>@item.TipoTarima</td>
                                        <td>@item.Medida</td>
                                        <td class="text-end">@item.Entradas</td>
                                        <td class="text-end">@item.Salidas</td>
                                        <td class="text-end fw-bold">@item.StockActual</td>
                                        <td class="text-end">@item.StockMinimo</td>
                                        <td>
                                            @if (item.StockActual <= 0)
                                            {
                                                <span class="badge bg-danger">Sin inventario</span>
                                            }
                                            else if (item.StockActual <= item.StockMinimo)
                                            {
                                                <span class="badge bg-warning text-dark">Bajo mínimo</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success">Disponible</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-dark text-white">
                <i class="bi bi-clock-history me-1"></i>Historial de movimientos
            </div>
            <div class="card-body p-0">
                @if (!Model.Movimientos.Any())
                {
                    <div class="p-3 text-muted">No hay movimientos registrados.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th>Fecha</th>
                                    <th>Tipo de tarima</th>
                                    <th>Movimiento</th>
                                    <th class="text-end">Entrada</th>
                                    <th class="text-end">Salida</th>
                                    <th class="text-end">Saldo</th>
                                    <th>Referencia</th>
                                    <th>Motivo</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var mov in Model.Movimientos)
                                {
                                    var entrada = tiposEntrada.Contains(mov.TipoMovimiento) ? mov.Cantidad : 0;
                                    var salida = tiposSalida.Contains(mov.TipoMovimiento) ? mov.Cantidad : 0;

                                    <tr>
                                        <td>@mov.FechaMovimiento.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>
                                            <span class="fw-semibold">@mov.Codigo</span><br />
                                            <small class="text-muted">@mov.TipoTarima</small>
                                        </td>
                                        <td>
                                            @if (entrada > 0)
                                            {
                                                <span class="badge bg-success">@mov.TipoMovimiento</span>
                                            }
                                            else if (salida > 0)
                                            {
                                                <span class="badge bg-danger">@mov.TipoMovimiento</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">@mov.TipoMovimiento</span>
                                            }
                                        </td>
                                        <td class="text-end">@(entrada > 0 ? entrada.ToString() : "-")</td>
                                        <td class="text-end">@(salida > 0 ? salida.ToString() : "-")</td>
                                        <td class="text-end fw-bold">@mov.Saldo</td>
                                        <td>
                                            @if (mov.IdOrdenCompra.HasValue)
                                            {
                                                <span>Orden #@mov.IdOrdenCompra</span>
                                            }
                                            else if (mov.IdProduccion.HasValue)
                                            {
                                                <span>Producción #@mov.IdProduccion</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Sin referencia</span>
                                            }
                                        </td>
                                        <td>@(string.IsNullOrWhiteSpace(mov.Motivo) ? "-" : mov.Motivo)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>