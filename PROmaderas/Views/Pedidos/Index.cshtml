@model IEnumerable<PROmaderas.UI.Controllers.PedidoListadoDto>
@{
    ViewData["Title"] = "Pedidos";
    var estados = new[] { "Pendiente", "En Produccion", "Lista para Entrega", "Entregada", "Cancelada" };
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col">
            <h2>Pedidos</h2>
        </div>
        <div class="col text-end">
            @if (User.IsInRole("Administrador") || User.IsInRole("Vendedor"))
            {
                <a asp-action="Create" class="btn btn-warning">
                    <i class="bi bi-plus-circle me-1"></i>Nuevo Pedido
                </a>
            }
        </div>
    </div>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }


    <form method="get" asp-action="Index" class="row g-2 mb-4">
        <div class="col-md-3">
            <input type="text" name="filtroCliente" value="@ViewBag.FiltroCliente"
                   class="form-control" placeholder="Buscar por cliente..." />
        </div>
        <div class="col-md-2">
            <select name="filtroEstado" class="form-select">
                <option value="">Todos los estados</option>
                @foreach (var e in estados)
                {
                    <option value="@e" selected="@(ViewBag.FiltroEstado == e)">@e</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <input type="date" name="fechaDesde" value="@ViewBag.FechaDesde"
                   class="form-control" title="Fecha desde" />
        </div>
        <div class="col-md-2">
            <input type="date" name="fechaHasta" value="@ViewBag.FechaHasta"
                   class="form-control" title="Fecha hasta" />
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-secondary">
                <i class="bi bi-search me-1"></i>Filtrar
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>N° Orden</th>
                    <th>Cliente</th>
                    <th>Fecha</th>
                    <th>Vendedor</th>
                    <th>Subtotal</th>
                    <th>Impuesto</th>
                    <th>Total</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    var badgeClass = p.Estado switch
                    {
                        "Entregada" => "bg-success",
                        "Cancelada" => "bg-danger",
                        "En Produccion" => "bg-primary",
                        "Lista para Entrega" => "bg-info text-dark",
                        _ => "bg-warning text-dark"
                    };
                    <tr>
                        <td><strong>@p.NumeroOrden</strong></td>
                        <td>@p.Cliente</td>
                        <td>@p.Fecha.ToString("dd/MM/yyyy")</td>
                        <td>@p.Usuario</td>
                        <td>₡@p.Subtotal.ToString("N2")</td>
                        <td>₡@p.Impuestos.ToString("N2")</td>
                        <td><strong>₡@p.Total.ToString("N2")</strong></td>
                        <td><span class="badge @badgeClass">@p.Estado</span></td>
                        <td>
                            <a asp-action="Details" asp-route-id="@p.Id"
                               class="btn btn-sm btn-info" title="Ver detalle">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-4">
                            No hay pedidos registrados con los filtros aplicados.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if ((int)ViewBag.TotalPaginas > 1)
    {
        <nav>
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= (int)ViewBag.TotalPaginas; i++)
                {
                    <li class="page-item @(i == (int)ViewBag.PaginaActual ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-pagina="@i"
                           asp-route-filtroCliente="@ViewBag.FiltroCliente"
                           asp-route-filtroEstado="@ViewBag.FiltroEstado"
                           asp-route-fechaDesde="@ViewBag.FechaDesde"
                           asp-route-fechaHasta="@ViewBag.FechaHasta">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>
