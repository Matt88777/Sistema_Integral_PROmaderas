@model PROmaderas.Abstracciones.Models.PedidoAD
@{
    ViewData["Title"] = $"Pedido {Model.NumeroOrden}";
    var estados = new[] { "Pendiente", "En Produccion", "Lista para Entrega", "Entregada", "Cancelada" };
    bool puedeCambiar = (bool)(ViewBag.PuedeCambiarEstado ?? false)
                        && Model.Estado != "Cancelada" && Model.Estado != "Entregada";
    var badgeClass = Model.Estado switch
    {
        "Entregada" => "bg-success",
        "Cancelada" => "bg-danger",
        "En Produccion" => "bg-primary",
        "Lista para Entrega" => "bg-info text-dark",
        _ => "bg-warning text-dark"
    };
}

<div class="container mt-4">

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["Mensaje"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <div class="row mb-3 align-items-center">
        <div class="col">
            <h2>Orden <span class="text-warning">@Model.NumeroOrden</span></h2>
        </div>
        <div class="col-auto">
            <span class="badge @badgeClass fs-6">@Model.Estado</span>
        </div>
    </div>


    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-person-fill fs-4" style="color:#c9a03c"></i>
                        <div>
                            <div class="small text-muted">Cliente</div>
                            <strong>@Model.Cliente?.Nombre</strong>
                            <div class="small text-muted">Cédula: @Model.Cliente?.Cedula</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-calendar-event fs-4" style="color:#c9a03c"></i>
                        <div>
                            <div class="small text-muted">Fecha de la orden</div>
                            <strong>@Model.Fecha.ToString("dd/MM/yyyy")</strong>
                            <div class="small text-muted">@Model.Fecha.ToString("HH:mm") hrs</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-briefcase-fill fs-4" style="color:#c9a03c"></i>
                        <div>
                            <div class="small text-muted">Vendedor responsable</div>
                            <strong>@ViewBag.NombreVendedor</strong>
                        </div>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(Model.Observacion))
                {
                    <div class="col-12">
                        <div class="d-flex align-items-start gap-2">
                            <i class="bi bi-chat-left-text fs-5" style="color:#c9a03c"></i>
                            <div>
                                <div class="small text-muted">Observaciones</div>
                                <span>@Model.Observacion</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>


    @if (puedeCambiar)
    {
        <div class="card mb-4" style="border-color:#c9a03c;">
            <div class="card-header fw-bold" style="background-color:#c9a03c;color:#fff;">
                <i class="bi bi-arrow-repeat me-1"></i>Actualizar estado del pedido
            </div>
            <div class="card-body">
                <form asp-action="CambiarEstado" method="post" class="row g-2 align-items-end">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Nuevo estado</label>
                        <select name="nuevoEstado" class="form-select" required>
                            <option value="">— Seleccionar —</option>
                            @foreach (var e in estados)
                            {
                                if (e != Model.Estado)
                                {
                                    <option value="@e">@e</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-5">
                        <label class="form-label fw-semibold">Observación (opcional)</label>
                        <input type="text" name="observacion" class="form-control"
                               placeholder="Motivo del cambio..." maxlength="250" />
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-warning w-100"
                                onclick="return confirm('¿Confirma el cambio de estado?')">
                            <i class="bi bi-check-circle me-1"></i>Confirmar cambio
                        </button>
                    </div>
                </form>
            </div>
        </div>
    }


    <h4 class="mb-3">Productos del pedido</h4>
    <div class="table-responsive mb-4">
        <table class="table table-bordered table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Tipo de Tarima</th>
                    <th class="text-end">Precio Unit.</th>
                    <th class="text-center">Cantidad</th>
                    <th class="text-end">Subtotal</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Detalles != null && Model.Detalles.Any())
                {
                    @foreach (var item in Model.Detalles)
                    {
                        <tr>
                            <td>@item.Producto?.Nombre</td>
                            <td class="text-end">₡@item.PrecioUnit.ToString("N2")</td>
                            <td class="text-center">@item.Cantidad</td>
                            <td class="text-end">₡@item.TotalLinea.ToString("N2")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="4" class="text-center text-muted">Sin detalles registrados.</td></tr>
                }
            </tbody>
        </table>
    </div>


    <div class="row justify-content-end mb-4">
        <div class="col-md-4">
            <table class="table table-bordered">
                <tr><th>Subtotal</th><td class="text-end">₡@Model.Subtotal.ToString("N2")</td></tr>
                <tr><th>Impuesto (13%)</th><td class="text-end">₡@Model.Impuestos.ToString("N2")</td></tr>
                <tr class="fw-bold" style="background-color:#c9a03c;color:#1a1a1a;">
                    <th>TOTAL</th>
                    <td class="text-end">₡@Model.Total.ToString("N2")</td>
                </tr>
            </table>
        </div>
    </div>


    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="ExportarPdf" asp-route-id="@Model.Id" class="btn btn-danger">
            <i class="bi bi-file-pdf me-1"></i>PDF
        </a>
        <a asp-action="ExportarExcel" asp-route-id="@Model.Id" class="btn btn-success">
            <i class="bi bi-file-excel me-1"></i>Excel
        </a>
        <a asp-action="Create" class="btn btn-warning">
            <i class="bi bi-plus-circle me-1"></i>Nuevo Pedido
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Volver al listado
        </a>
    </div>

   
    @* OC-HU-004: Historial de cambios de estado *@
    @{
        var histList = ViewBag.Historial as List<PROmaderas.UI.Controllers.HistorialItemDto>;
    }
    @if (histList != null && histList.Any())
    {
        <hr class="my-4" />
        <h5 class="mb-3">
            <i class="bi bi-clock-history me-2 text-warning"></i>Historial de cambios de estado
        </h5>
        <div class="table-responsive mb-4">
            <table class="table table-sm table-bordered">
                <thead class="table-secondary">
                    <tr>
                        <th>Fecha y hora</th>
                        <th>Estado anterior</th>
                        <th>Estado nuevo</th>
                        <th>Realizado por</th>
                        <th>Observacion</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var h in histList)
                    {
                        <tr>
                            <td class="text-nowrap">@h.FechaCambio.ToString("dd/MM/yyyy HH:mm")</td>
                            <td><span class="badge bg-secondary">@h.EstadoAnterior</span></td>
                            <td><span class="badge bg-warning text-dark">@h.EstadoNuevo</span></td>
                            <td>@h.UsuarioCambio</td>
                            <td class="text-muted">@h.Observacion</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
