@model ErrorViewModel
@{
    ViewData["Title"] = "Error - Algo salió mal";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="error-template">
                <h1 class="display-4 text-danger">¡Oops!</h1>
                <h2 class="mb-4">Ha ocurrido un error inesperado</h2>
                <p class="lead text-muted mb-4">
                    Lo sentimos, algo salió mal mientras procesábamos tu solicitud.
                </p>

                @if (Model.ShowRequestId)
                {
                    <div class="alert alert-info" role="alert">
                        <strong>ID de Solicitud:</strong> <code>@Model.RequestId</code>
                    </div>
                }

                <div class="error-actions mb-5">
                    <div class="row">
                        <div class="col-md-6">
                            <a asp-controller="Productos" asp-action="Index" class="btn btn-primary btn-lg">
                                <i class="bi bi-house-door"></i> Ir al Inicio
                            </a>
                        </div>
                        <div class="col-md-6">
                            <a href="javascript:history.back()" class="btn btn-secondary btn-lg">
                                <i class="bi bi-arrow-left"></i> Volver Atrás
                            </a>
                        </div>
                    </div>
                </div>

                <div class="mt-5">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">¿Qué puedes hacer?</h5>
                            <div class="row text-start">
                                <div class="col-md-6">
                                    <ul class="list-unstyled">
                                        <li><i class="bi bi-check text-success"></i> Recargar la página</li>
                                        <li><i class="bi bi-check text-success"></i> Verificar tu conexión a internet</li>
                                    </ul>
                                </div>
                                <div class="col-md-6">
                                    <ul class="list-unstyled">
                                        <li><i class="bi bi-check text-success"></i> Intentar de nuevo más tarde</li>
                                        <li><i class="bi bi-check text-success"></i> Contactar soporte técnico</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .error-template {
        padding: 40px 15px;
    }
    .error-actions {
        margin-top: 15px;
        margin-bottom: 15px;
    }
    .error-actions .btn {
        margin: 5px;
    }
</style>
