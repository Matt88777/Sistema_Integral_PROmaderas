@{
	ViewData["Title"] = ViewBag.TituloModulo ?? "Módulo en construcción";
	var modulo = ViewBag.Modulo as string ?? "Este módulo";
	var detalle = ViewBag.Detalle as string ?? "Estará disponible en el próximo sprint.";
}

<div class="container mt-5">
	<div class="row justify-content-center">
		<div class="col-md-8 text-center">
			<div class="card shadow-sm">
				<div class="card-body p-5">
					<div class="display-1 text-warning mb-3">
						<i class="bi bi-cone-striped"></i>
					</div>
					<h2 class="mb-3">@modulo está en construcción</h2>
					<p class="lead text-muted mb-4">@detalle</p>
					<a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary">
						<i class="bi bi-house-door me-2"></i>Volver al dashboard
					</a>
				</div>
			</div>
		</div>
	</div>
</div>
