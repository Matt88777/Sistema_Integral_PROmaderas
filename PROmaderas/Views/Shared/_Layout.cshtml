<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PROMADERAS</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="app-shell">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark promaderas-navbar mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Dashboard" asp-action="Index">PROMADERAS</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Productos" asp-action="Index">Inventario</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Clientes" asp-action="Index">Clientes</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Pedidos" asp-action="Index">Órdenes de compra</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Facturacion" asp-action="Index">Facturación</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Planilla" asp-action="Index">Planilla</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Empleados" asp-action="Index">
                                    Empleados
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Reportes" asp-action="Index">Reportes</a>
                            </li>

                            @if (User.IsInRole("Administrador"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="AdminUsuarios" asp-action="Index">Usuarios</a>
                                </li>
                            }
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <!-- TARIMA -->
                            <li class="nav-item d-flex align-items-center">
                                <img src="~/images/tarima.png" class="tarima-animada me-3" width="40" />
                            </li>

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle me-1"></i>
                                    @{
                                        var displayName = User.Claims.FirstOrDefault(c => c.Type == "DisplayName")?.Value ?? User.Identity?.Name;
                                    }
                                    @displayName
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><h6 class="dropdown-header">Sesión activa</h6></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item">
                                                <i class="bi bi-box-arrow-right me-2"></i>Cerrar sesión
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">Iniciar sesión</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container app-content-wrap">
        <main role="main" class="pb-3 app-content-panel">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container">
            &copy; 2026 - PROMADERAS
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>