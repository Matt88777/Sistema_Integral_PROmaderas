<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PROMADERAS</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="app-shell">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark promaderas-navbar mb-3" id="mainNav">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Dashboard" asp-action="Index">PROMADERAS</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                            </li>

                            <li class="nav-item mega-parent">
                                <a class="nav-link" href="javascript:void(0)">
                                    Operaciones <i class="bi bi-chevron-down" style="font-size:0.65em;opacity:0.75;margin-left:2px"></i>
                                </a>
                                <ul class="dropdown-menu mega-menu" style="display:none">

                                    @* INVENTARIO *@
                                    @if (User.IsInRole("Administrador") || User.IsInRole("Gerente") || User.IsInRole("Operador de Planta"))
                                    {
                                        <li class="mega-menu-col">
                                            <span class="mega-menu-header"><i class="bi bi-boxes me-1"></i>Inventario</span>
                                            <a class="dropdown-item" asp-controller="Productos" asp-action="Index"><i class="bi bi-list-ul me-2"></i>Ver productos</a>
                                            <a class="dropdown-item" asp-controller="Productos" asp-action="Inventario"><i class="bi bi-search me-2"></i>Consultar inventario</a>
                                            <a class="dropdown-item" asp-controller="Productos" asp-action="AjustesInventario"><i class="bi bi-pencil-square me-2"></i>Ajustes de inventario</a>
                                            <a class="dropdown-item" asp-controller="Productos" asp-action="Create"><i class="bi bi-plus-circle me-2"></i>Nuevo producto</a>
                                            <div class="dropdown-divider"></div>
                                            <span class="mega-menu-header"><i class="bi bi-clipboard2-check me-1"></i>Producción</span>
                                            <a class="dropdown-item" asp-controller="Produccion" asp-action="Index"><i class="bi bi-clock-history me-2"></i>Historial de producción</a>
                                            <a class="dropdown-item" asp-controller="Produccion" asp-action="Registrar"><i class="bi bi-clipboard2-plus me-2"></i>Registrar producción</a>
                                        </li>
                                    }

                                    @* CLIENTES *@
                                    @if (User.IsInRole("Administrador") || User.IsInRole("Gerente") || User.IsInRole("Vendedor"))
                                    {
                                        <li class="mega-menu-col">
                                            <span class="mega-menu-header"><i class="bi bi-people me-1"></i>Clientes</span>
                                            <a class="dropdown-item" asp-controller="Clientes" asp-action="Index"><i class="bi bi-person-lines-fill me-2"></i>Ver clientes</a>
                                            <a class="dropdown-item" asp-controller="Clientes" asp-action="Create"><i class="bi bi-person-plus me-2"></i>Nuevo cliente</a>
                                        </li>
                                    }

                                    @* ÓRDENES DE COMPRA *@
                                    @if (User.IsInRole("Administrador") || User.IsInRole("Gerente") || User.IsInRole("Contador") ||
                                         User.IsInRole("Operador de Planta") || User.IsInRole("Vendedor") || User.IsInRole("Usuario"))
                                    {
                                        <li class="mega-menu-col">
                                            <span class="mega-menu-header"><i class="bi bi-cart3 me-1"></i>Órdenes de compra</span>
                                            <a class="dropdown-item" asp-controller="Pedidos" asp-action="Index"><i class="bi bi-clipboard-list me-2"></i>Ver órdenes</a>
                                            <a class="dropdown-item" asp-controller="Pedidos" asp-action="Create"><i class="bi bi-plus-circle me-2"></i>Nueva orden</a>
                                        </li>
                                    }

                                    @* FACTURACIÓN *@
                                    @if (User.IsInRole("Administrador") || User.IsInRole("Contador") || User.IsInRole("Gerente"))
                                    {
                                        <li class="mega-menu-col">
                                            <span class="mega-menu-header"><i class="bi bi-receipt me-1"></i>Facturación</span>
                                            <a class="dropdown-item" asp-controller="Facturacion" asp-action="Index"><i class="bi bi-receipt me-2"></i>Ver facturas</a>
                                            @if (User.IsInRole("Administrador") || User.IsInRole("Contador"))
                                            {
                                                <a class="dropdown-item" asp-controller="Facturacion" asp-action="Create"><i class="bi bi-plus-circle me-2"></i>Nueva factura</a>
                                            }
                                        </li>
                                    }

                                    <li class="mega-menu-footer">
                                        <a asp-controller="Dashboard" asp-action="Index">
                                            <i class="bi bi-house me-1"></i>Ver Panel principal →
                                        </a>
                                    </li>

                                </ul>
                            </li>

                            @* ADMINISTRACIÓN *@
                            @if (User.IsInRole("Administrador") || User.IsInRole("Gerente") || User.IsInRole("Contador"))
                            {
                                <li class="nav-item mega-parent">
                                    <a class="nav-link" href="javascript:void(0)">
                                        Administración <i class="bi bi-chevron-down" style="font-size:0.65em;opacity:0.75;margin-left:2px"></i>
                                    </a>
                                    <ul class="dropdown-menu mega-menu" style="display:none">

                                        @* PLANILLA *@
                                        @if (User.IsInRole("Administrador") || User.IsInRole("Contador"))
                                        {
                                            <li class="mega-menu-col">
                                                <span class="mega-menu-header"><i class="bi bi-cash-stack me-1"></i>Planilla</span>
                                                <a class="dropdown-item" asp-controller="Planilla" asp-action="Index"><i class="bi bi-table me-2"></i>Ver planilla</a>
                                                @* PLA-HU-019: configurar parámetros es solo del Administrador. *@
                                                @if (User.IsInRole(Roles.Administrador))
                                                {
                                                    <a class="dropdown-item" asp-controller="Parametros" asp-action="Index"><i class="bi bi-sliders me-2"></i>Parámetros de planilla</a>
                                                    @* PLA-HU-012: la HU dice "Como Administrador"; el Contador no entra. *@
                                                    <a class="dropdown-item" asp-controller="Vacaciones" asp-action="Index"><i class="bi bi-umbrella me-2"></i>Vacaciones</a>
                                                }
                                                @* PLA-HU-017: la HU dice "Como Contador", así que acá SÍ entra
                                                   (el bloque ya está limitado a Administrador o Contador). *@
                                                <a class="dropdown-item" asp-controller="Liquidaciones" asp-action="Index"><i class="bi bi-file-earmark-text me-2"></i>Liquidaciones</a>
                                            </li>
                                        }

                                        @* EMPLEADOS *@
                                        @if (User.IsInRole("Administrador"))
                                        {
                                            <li class="mega-menu-col">
                                                <span class="mega-menu-header"><i class="bi bi-person-badge me-1"></i>Empleados</span>
                                                <a class="dropdown-item" asp-controller="Empleados" asp-action="Index"><i class="bi bi-people-fill me-2"></i>Ver empleados</a>
                                                <a class="dropdown-item" asp-controller="Empleados" asp-action="Create"><i class="bi bi-person-plus me-2"></i>Nuevo empleado</a>
                                            </li>
                                        }
                                        @* LICENCIAS *@
                                        @if (User.IsInRole("Administrador"))
                                        {
                                            <li class="mega-menu-col">
                                                <span class="mega-menu-header"><i class="bi bi-calendar2-week me-1"></i>Licencias</span>
                                                <a class="dropdown-item" asp-controller="Licencias" asp-action="Index"><i class="bi bi-calendar2-check me-2"></i>Ver licencias</a>
                                                <a class="dropdown-item" asp-controller="Licencias" asp-action="Create"><i class="bi bi-calendar2-plus me-2"></i>Nueva licencia</a>
                                            </li>
                                        }
                                        @* AGUINALDO *@
                                        @if (User.IsInRole("Administrador") || User.IsInRole("Contador"))
                                        {
                                            <li class="mega-menu-col">
                                                <span class="mega-menu-header"><i class="bi bi-gift me-1"></i>Aguinaldo</span>
                                                <a class="dropdown-item" asp-controller="Aguinaldo" asp-action="Index"><i class="bi bi-calculator me-2"></i>Calcular aguinaldo</a>
                                            </li>
                                        }

                                        @* HISTORIAL DE PAGOS *@
                                        @if (User.IsInRole("Administrador") || User.IsInRole("Contador"))
                                        {
                                            <li class="mega-menu-col">
                                                <span class="mega-menu-header"><i class="bi bi-clock-history me-1"></i>Historial de Pagos</span>
                                                <a class="dropdown-item" asp-controller="HistorialPagos" asp-action="Index"><i class="bi bi-file-earmark-text me-2"></i>Ver historial</a>
                                            </li>
                                        }

                                        @* REPORTES *@
                                        @if (User.IsInRole("Administrador") || User.IsInRole("Gerente") || User.IsInRole("Contador"))
                                        {
                                            <li class="mega-menu-col">
                                                <span class="mega-menu-header"><i class="bi bi-bar-chart me-1"></i>Reportes</span>
                                                <a class="dropdown-item" asp-controller="Reportes" asp-action="Index"><i class="bi bi-graph-up me-2"></i>Ver reportes</a>
                                            </li>
                                        }

                                        @* USUARIOS *@
                                        @if (User.IsInRole("Administrador"))
                                        {
                                            <li class="mega-menu-col">
                                                <span class="mega-menu-header"><i class="bi bi-shield-lock me-1"></i>Sistema</span>
                                                <a class="dropdown-item" asp-controller="AdminUsuarios" asp-action="Index"><i class="bi bi-people me-2"></i>Gestión de usuarios</a>
                                                <a class="dropdown-item" asp-controller="AdminUsuarios" asp-action="Create"><i class="bi bi-person-plus me-2"></i>Nuevo usuario</a>
                                            </li>
                                        }

                                        <li class="mega-menu-footer">
                                            <a asp-controller="Reportes" asp-action="Index">Ver todos los reportes →</a>
                                        </li>

                                    </ul>
                                </li>
                            }
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item d-flex align-items-center">
                                <img src="~/images/tarima.png" class="tarima-animada me-3" width="40" />
                            </li>

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle me-1"></i>
                                    @{
                                        var displayName = User.Claims.FirstOrDefault(c => c.Type == "DisplayName")?.Value ?? User.Identity?.Name;
                                    }
                                    @displayName
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><h6 class="dropdown-header">Sesión activa</h6></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="Perfil">
                                            <i class="bi bi-person-gear me-2"></i>Mi Perfil
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item">
                                                <i class="bi bi-box-arrow-right me-2"></i>Cerrar sesión
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">Iniciar sesión</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container app-content-wrap">
        <main role="main" class="pb-3 app-content-panel">
            @RenderBody()
        </main>
    </div>

    <footer>
        <div class="promaderas-footer">
            <span class="footer-brand">PROMADERAS</span>
            <span class="footer-copy">&copy; 2026 — Sistema Integral de Gestión</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        (function () {
        var nav = document.getElementById('mainNav');
        if (!nav) return;

        nav.querySelectorAll('.mega-parent').forEach(function (item) {
        var menu = item.querySelector('.dropdown-menu.mega-menu');
        if (!menu) return;

        var timer = null;

        function posicionarYAbrir() {
        clearTimeout(timer);
        var rect = nav.getBoundingClientRect();
        menu.style.position = 'fixed';
        menu.style.top = rect.bottom + 'px';
        menu.style.left = rect.left + 'px';
        menu.style.width = rect.width + 'px';
        menu.style.right = 'auto';
        menu.style.display = 'grid';
        }

        function cerrar() {
        timer = setTimeout(function () {
        menu.style.display = 'none';
        }, 100);
        }

        item.addEventListener('mouseenter', posicionarYAbrir);
        item.addEventListener('mouseleave', cerrar);
        menu.addEventListener('mouseenter', function () { clearTimeout(timer); });
        menu.addEventListener('mouseleave', cerrar);
        });

        document.addEventListener('click', function (e) {
        if (!nav.contains(e.target)) {
        nav.querySelectorAll('.dropdown-menu.mega-menu').forEach(function (m) {
        m.style.display = 'none';
        });
        }
        });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
