@model List<VacacionAD>
@{
    var saldo = (SaldoVacacionesAD)ViewBag.Saldo;
    ViewData["Title"] = $"Vacaciones de {saldo.NombreCompleto}";
}

<partial name="_TemaOscuro" />

<div class="container mt-4">
    <div class="row mb-3 align-items-center">
        <div class="col">
            <h2>
                <i class="bi bi-umbrella me-2" style="color:#c9a03c"></i>
                Vacaciones — <span style="color:#c9a03c">@saldo.NombreCompleto</span>
            </h2>
        </div>
        <div class="col-auto d-flex gap-2">
            <a asp-action="Create" asp-route-idEmpleado="@saldo.IdEmpleado" class="btn btn-warning fw-bold">
                <i class="bi bi-calendar2-plus me-1"></i>Registrar vacación
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Volver
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-1"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle me-1"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!saldo.TieneFechaIngreso)
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-octagon me-1"></i>
            <strong>El empleado no tiene fecha de ingreso registrada.</strong>
            Sin ese dato no se pueden calcular los meses trabajados ni los días acumulados.
            Corríjalo en <strong>Empleados &gt; Editar</strong>; mientras tanto no se le pueden
            registrar vacaciones.
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <div class="small text-muted mb-1">
                        <i class="bi bi-plus-circle me-1"></i>Acumuladas
                    </div>
                    <h3 class="mb-0 fw-bold">
                        @(saldo.TieneFechaIngreso ? saldo.Acumuladas.ToString("N2") : "—")
                    </h3>
                    <div class="small text-muted mt-2">
                        Saldo inicial @saldo.SaldoInicial.ToString("N2")
                        + @saldo.MesesTrabajados mes(es) trabajado(s)
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <div class="small text-muted mb-1">
                        <i class="bi bi-dash-circle me-1"></i>Disfrutadas
                    </div>
                    <h3 class="mb-0 fw-bold">@saldo.Disfrutadas.ToString("N2")</h3>
                    <div class="small text-muted mt-2">
                        Días ya tomados (las anuladas no cuentan)
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <div class="small text-muted mb-1">
                        <i class="bi bi-wallet2 me-1"></i>Saldo disponible
                    </div>
                    <h3 class="mb-0 fw-bold" style="color:#c9a03c">
                        @(saldo.TieneFechaIngreso ? saldo.Saldo.ToString("N2") : "—")
                    </h3>
                    <div class="small text-muted mt-2">
                        @(saldo.TieneFechaIngreso
                            ? $"Ingresó el {saldo.FechaIngreso!.Value:dd/MM/yyyy}"
                            : "Sin fecha de ingreso")
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="alert alert-secondary">
        <i class="bi bi-shield-check me-1"></i>
        Una vacación <strong>no se edita</strong>: si quedó mal digitada se <strong>anula</strong>
        (con motivo, que queda en la bitácora) y se registra de nuevo. Al anularla, sus días
        <strong>vuelven al saldo</strong>.
    </div>

    <h5 class="mb-3"><i class="bi bi-clock-history me-1"></i>Historial</h5>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Desde</th>
                    <th>Hasta</th>
                    <th class="text-end">Días</th>
                    <th>Estado</th>
                    <th>Observación</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var v in Model)
                {
                    var anulada = v.Estado == EstadosVacacion.Anulada;
                    @* pm-fila-anulada: atenuada pero legible sobre el fondo oscuro. *@
                    <tr class="@(anulada ? "pm-fila-anulada" : "")">
                        <td>@v.FechaInicio.ToString("dd/MM/yyyy")</td>
                        <td>@v.FechaFin.ToString("dd/MM/yyyy")</td>
                        <td class="text-end fw-bold">@v.Dias.ToString("N2")</td>
                        <td>
                            @if (anulada)
                            {
                                <span class="badge" style="background:#64748B;color:#fff">Anulada</span>
                            }
                            else
                            {
                                <span class="badge" style="background:#15803D;color:#fff">Disfrutada</span>
                            }
                        </td>
                        <td>@(string.IsNullOrWhiteSpace(v.Observacion) ? "—" : v.Observacion)</td>
                        <td class="text-center">
                            @if (!anulada)
                            {
                                <button type="button" class="btn btn-sm btn-outline-danger"
                                        data-bs-toggle="modal"
                                        data-bs-target="#modalAnular-@v.IdVacacion"
                                        title="Anular vacación">
                                    <i class="bi bi-slash-circle"></i>
                                </button>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            <i class="bi bi-inbox me-1"></i>Este empleado no tiene vacaciones registradas.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* Un modal de confirmación por vacación: la anulación pide motivo obligatorio.
       modal-pm: lo engancha con los estilos oscuros de _TemaOscuro. *@
    @foreach (var v in Model.Where(x => x.Estado != EstadosVacacion.Anulada))
    {
        <div class="modal fade modal-pm" id="modalAnular-@v.IdVacacion" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
                <form asp-action="Anular" method="post" class="modal-content">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="idVacacion" value="@v.IdVacacion" />
                    <input type="hidden" name="idEmpleado" value="@saldo.IdEmpleado" />

                    <div class="modal-header">
                        <h5 class="modal-title">
                            <i class="bi bi-slash-circle me-1 text-danger"></i>Anular vacación
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">
                        <div class="alert alert-warning">
                            <strong>Las vacaciones no se editan.</strong>
                            Al anular esta, sus <strong>@v.Dias.ToString("N2") día(s)</strong> vuelven
                            al saldo del empleado y la fila queda en el historial como evidencia.
                            Si el dato estaba mal, regístrela de nuevo con los valores correctos.
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-6">
                                <div class="small text-muted">Período</div>
                                <strong>
                                    @v.FechaInicio.ToString("dd/MM/yyyy") — @v.FechaFin.ToString("dd/MM/yyyy")
                                </strong>
                            </div>
                            <div class="col-6">
                                <div class="small text-muted">Días</div>
                                <strong>@v.Dias.ToString("N2")</strong>
                            </div>
                        </div>

                        <label class="form-label fw-semibold">
                            Motivo de la anulación <span class="text-danger">*</span>
                        </label>
                        <textarea name="motivo" class="form-control" rows="3" required
                                  placeholder="Ej. Se digitaron 10 días en vez de 5."></textarea>
                        <div class="form-text">Queda registrado en la bitácora de auditoría.</div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                            Cancelar
                        </button>
                        <button type="submit" class="btn btn-danger fw-bold">
                            <i class="bi bi-check-circle me-1"></i>Anular vacación
                        </button>
                    </div>
                </form>
            </div>
        </div>
    }
</div>

<script>
    // El panel del tema (<main class="app-content-panel">) usa backdrop-filter, y un ancestro
    // con backdrop-filter se vuelve el containing block de sus descendientes position:fixed.
    // Resultado: el modal de Bootstrap se posiciona y recorta contra el panel en vez de contra
    // el viewport (por eso salía cortado). Moverlos a <body> los devuelve al viewport.
    // Por eso sus estilos se enganchan con .modal-pm y no con .app-content-panel: acá dejan
    // de estar dentro del panel.
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.modal-pm').forEach(function (m) {
            document.body.appendChild(m);
        });
    });
</script>
