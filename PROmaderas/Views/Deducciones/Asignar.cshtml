@using PROmaderas.Abstracciones.Models
@model List<EmpleadoDeduccionAD>
@{
    ViewData["Title"] = "Asignar deducciones";
    var empleado = ViewBag.Empleado as EmpleadoAD;
    var disponibles = ViewBag.Disponibles as List<DeduccionInternaAD> ?? new List<DeduccionInternaAD>();
}

<div class="container mt-4">
    <div class="row mb-3 align-items-center">
        <div class="col">
            <h2>
                <i class="bi bi-person-gear me-2" style="color:#c9a03c"></i>
                Deducciones — @empleado?.Nombre @empleado?.PrimerApellido
            </h2>
        </div>
        <div class="col-auto">
            <a asp-action="Index" class="btn btn-accion-ver">
                <i class="bi bi-arrow-left me-1"></i>Volver
            </a>
        </div>
    </div>

    @if (disponibles.Any())
    {
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="mb-3">Agregar deducción</h5>
                <form asp-action="AsignarDeduccion" method="post" class="d-flex gap-2 align-items-center">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="idEmpleado" value="@empleado?.IdEmpleado" />
                    <select name="idDeduccion" class="form-select" style="max-width:300px" required>
                        <option value="">Seleccione...</option>
                        @foreach (var d in disponibles)
                        {
                            <option value="@d.IdDeduccion">
                                @d.Nombre — @(d.EsPorcentaje ? $"{d.Porcentaje}%" : d.Monto?.ToString("C2"))
                            </option>
                        }
                    </select>
                    <button type="submit" class="btn btn-warning fw-bold">
                        <i class="bi bi-plus-circle me-1"></i>Asignar
                    </button>
                </form>
            </div>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Deducción</th>
                    <th>Tipo</th>
                    <th>Valor</th>
                    <th class="text-center">Quitar</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model)
                {
                    <tr>
                        <td class="fw-semibold">@a.Deduccion?.Nombre</td>
                        <td>@(a.Deduccion?.EsPorcentaje == true ? "Porcentaje" : "Monto fijo")</td>
                        <td>
                            @if (a.Deduccion?.EsPorcentaje == true)
                            {
                                <span>@a.Deduccion.Porcentaje %</span>
                            }
                            else
                            {
                                <span>@a.Deduccion?.Monto?.ToString("C2")</span>
                            }
                        </td>
                        <td class="text-center">
                            <form asp-action="Desasignar" method="post" class="d-inline m-0">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="idEmpleadoDeduccion" value="@a.IdEmpleadoDeduccion" />
                                <input type="hidden" name="idEmpleado" value="@empleado?.IdEmpleado" />
                                <button type="submit" class="btn btn-sm btn-accion-eliminar" title="Quitar">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">
                            <i class="bi bi-inbox me-1"></i>Sin deducciones asignadas.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>