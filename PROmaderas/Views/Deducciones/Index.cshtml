@using PROmaderas.Abstracciones.Models
@model List<DeduccionInternaAD>
@{
    ViewData["Title"] = "Deducciones internas";
}

<div class="container mt-4">
    <div class="row mb-3 align-items-center">
        <div class="col">
            <h2><i class="bi bi-scissors me-2" style="color:#c9a03c"></i>Deducciones internas</h2>
        </div>
        <div class="col-auto">
            <a asp-action="Create" class="btn btn-warning fw-bold">
                <i class="bi bi-plus-circle me-1"></i>Nueva deducción
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-1"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle me-1"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Nombre</th>
                    <th>Tipo</th>
                    <th>Valor</th>
                    <th>Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in Model)
                {
                    <tr>
                        <td class="fw-semibold">@d.Nombre</td>
                        <td>@(d.EsPorcentaje ? "Porcentaje" : "Monto fijo")</td>
                        <td>
                            @if (d.EsPorcentaje)
                            {
                                <span>@d.Porcentaje %</span>
                            }
                            else
                            {
                                <span>@d.Monto?.ToString("C2")</span>
                            }
                        </td>
                        <td>
                            <span class="badge @(d.Activa ? "bg-success" : "bg-secondary")">
                                @(d.Activa ? "Activa" : "Inactiva")
                            </span>
                        </td>
                        <td class="text-center">
                            <div class="d-flex gap-2 justify-content-center">
                                <a asp-action="Edit" asp-route-id="@d.IdDeduccion"
                                   class="btn btn-sm btn-accion-editar" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="Eliminar" method="post" class="d-inline m-0">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@d.IdDeduccion" />
                                    <button type="submit" class="btn btn-sm btn-accion-eliminar" title="Eliminar">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            <i class="bi bi-inbox me-1"></i>No hay deducciones configuradas.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>