@using PROmaderas.Abstracciones.Models
@model DeduccionInternaAD
@{
    ViewData["Title"] = "Editar deducción";
}

<div class="container mt-4" style="max-width:540px">
    <h2 class="mb-4"><i class="bi bi-scissors me-2" style="color:#c9a03c"></i>Editar deducción</h2>

    <div class="card">
        <div class="card-body">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="IdDeduccion" />

                <div class="mb-3">
                    <label class="form-label">Nombre</label>
                    <input asp-for="Nombre" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Tipo</label>
                    <select asp-for="EsPorcentaje" class="form-select" id="tipoSelect">
                        <option value="false">Monto fijo</option>
                        <option value="true">Porcentaje del bruto</option>
                    </select>
                </div>

                <div class="mb-3" id="campoMonto">
                    <label class="form-label">Monto (₡)</label>
                    <input asp-for="Monto" type="number" step="0.01" min="0" class="form-control" />
                </div>

                <div class="mb-3 d-none" id="campoPorcentaje">
                    <label class="form-label">Porcentaje (%)</label>
                    <input asp-for="Porcentaje" type="number" step="0.01" min="0" max="100" class="form-control" />
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="Activa" class="form-check-input" type="checkbox" />
                    <label class="form-check-label" asp-for="Activa">Activa</label>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning fw-bold">
                        <i class="bi bi-floppy me-1"></i>Guardar
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    var sel = document.getElementById('tipoSelect');
    var campoMonto = document.getElementById('campoMonto');
    var campoPorcentaje = document.getElementById('campoPorcentaje');
    function toggle() {
        var esPorcentaje = sel.value === 'true';
        campoMonto.classList.toggle('d-none', esPorcentaje);
        campoPorcentaje.classList.toggle('d-none', !esPorcentaje);
    }
    sel.addEventListener('change', toggle);
    toggle();
</script>