@model PROmaderas.UI.Models.CambiarEstadoFacturaViewModel
@{
    ViewData["Title"] = "Cambiar estado de factura";
}

<div class="container mt-4" style="max-width:640px">
    <div class="row mb-3 align-items-center">
        <div class="col">
            <h2><i class="bi bi-arrow-repeat me-2" style="color:#c9a03c"></i>Cambiar estado</h2>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <div class="small text-muted">N° Factura</div>
                    <strong style="color:#c9a03c">@Model.NumeroFactura</strong>
                </div>
                <div class="col-md-6">
                    <div class="small text-muted">Estado actual</div>
                    <strong>@Model.EstadoActual</strong>
                </div>
            </div>

            <form asp-action="CambiarEstado" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="FacturaId" />
                <input type="hidden" asp-for="NumeroFactura" />
                <input type="hidden" asp-for="EstadoActual" />

                <div class="mb-4">
                    <label class="form-label fw-semibold">Nuevo estado</label>
                    <select name="NuevoEstado" class="form-select">
                        <option value="@EstadosFactura.Emitida"
                                selected="@(Model.NuevoEstado == EstadosFactura.Emitida)">
                            @EstadosFactura.Emitida
                        </option>
                        <option value="@EstadosFactura.PendienteDePago"
                                selected="@(Model.NuevoEstado == EstadosFactura.PendienteDePago)">
                            @EstadosFactura.PendienteDePago
                        </option>
                    </select>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning fw-bold px-4">
                        <i class="bi bi-check-circle me-1"></i>Guardar
                    </button>
                    <a asp-action="Details" asp-route-id="@Model.FacturaId" class="btn btn-outline-secondary">
                        <i class="bi bi-x-lg me-1"></i>Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
