@model PROmaderas.UI.Models.ConsultaFacturasViewModel
@{
    ViewData["Title"] = "Facturas";
    int paginaActual = ViewBag.PaginaActual != null ? (int)ViewBag.PaginaActual : 1;
    int totalPaginas = ViewBag.TotalPaginas != null ? (int)ViewBag.TotalPaginas : 1;
}

<div class="container mt-4">
    <div class="row mb-3 align-items-center">
        <div class="col">
            <h2><i class="bi bi-receipt me-2" style="color:#c9a03c"></i>Facturas</h2>
        </div>
        @if (User.IsInRole("Administrador") || User.IsInRole("Contador"))
        {
            <div class="col-auto">
                <a asp-action="Create" class="btn btn-warning fw-bold px-4">
                    <i class="bi bi-plus-circle me-1"></i>Nueva Factura
                </a>
            </div>
        }
    </div>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-1"></i>@TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form method="get" asp-action="Index" class="card card-body bg-light border-0 shadow-sm mb-4">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label fw-semibold mb-1">Cliente</label>
                <select name="clienteId" class="form-select">
                    <option value="">Todos los clientes</option>
                    @foreach (var c in Model.Clientes)
                    {
                        <option value="@c.Id" selected="@(Model.ClienteId == c.Id)">@c.Nombre</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label fw-semibold mb-1">Desde</label>
                <input type="date" name="fechaDesde" class="form-control"
                       value="@(Model.FechaDesde?.ToString("yyyy-MM-dd"))" />
            </div>
            <div class="col-md-2">
                <label class="form-label fw-semibold mb-1">Hasta</label>
                <input type="date" name="fechaHasta" class="form-control"
                       value="@(Model.FechaHasta?.ToString("yyyy-MM-dd"))" />
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold mb-1">N° Factura</label>
                <input type="text" name="numeroFactura" class="form-control"
                       placeholder="Ej. FAC-2024..." value="@Model.NumeroFactura" />
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-warning fw-bold flex-fill">
                    <i class="bi bi-search me-1"></i>Filtrar
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary" title="Limpiar filtros">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </div>
    </form>

    @if (!Model.Facturas.Any())
    {
        <div class="alert alert-info"><i class="bi bi-info-circle me-1"></i>No se encontraron facturas con esos criterios.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>N° Factura</th>
                        <th>Orden</th>
                        <th>Cliente</th>
                        <th>Fecha</th>
                        <th class="text-end">Subtotal</th>
                        <th class="text-end">Exoneración</th>
                        <th class="text-end">IVA</th>
                        <th class="text-end">Total</th>
                        <th>Estado</th>
                        <th class="text-center" style="min-width:80px">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var f in Model.Facturas)
                    {
                        <tr>
                            <td class="fw-semibold" style="color:#c9a03c">@f.NumeroFactura</td>
                            <td>@f.Pedido?.NumeroOrden</td>
                            <td>@f.Cliente?.Nombre</td>
                            <td>@f.Fecha.ToString("dd/MM/yyyy")</td>
                            <td class="text-end">₡@f.Subtotal.ToString("N2")</td>
                            <td class="text-end text-success">@(f.Exoneracion > 0 ? "₡" + f.Exoneracion.ToString("N2") : "—")</td>
                            <td class="text-end">₡@f.Impuestos.ToString("N2")</td>
                            <td class="text-end fw-bold">₡@f.Total.ToString("N2")</td>
                            <td>
                                @if (f.Estado == EstadosFactura.Pagada)
                                {
                                    <span class="badge" style="background:#15803D;color:#fff">@EstadosFactura.Pagada</span>
                                }
                                else if (f.Estado == EstadosFactura.Emitida)
                                {
                                    <span class="badge" style="background:#0369A1;color:#fff">@EstadosFactura.Emitida</span>
                                }
                                else if (f.Estado == EstadosFactura.PendienteDePago)
                                {
                                    <span class="badge" style="background:#B45309;color:#fff">@EstadosFactura.PendienteDePago</span>
                                }
                                else if (f.Estado == EstadosFactura.Anulada)
                                {
                                    <span class="badge" style="background:#475569;color:#fff">@EstadosFactura.Anulada</span>
                                }
                                else
                                {
                                    <span class="badge" style="background:#374151;color:#fff">@f.Estado</span>
                                }
                            </td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@f.Id"
                                   class="btn btn-sm btn-accion-ver" title="Ver detalles">
                                    <i class="bi bi-eye"></i>
                                </a>
                                @if (User.IsInRole("Administrador") || User.IsInRole("Contador"))
                                {
                                    <a asp-action="CambiarEstado" asp-route-id="@f.Id"
                                       class="btn btn-sm btn-outline-secondary" title="Cambiar estado">
                                        <i class="bi bi-arrow-repeat"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* Paginación inactiva en FAC-HU-002: el Index no alimenta TotalPaginas, así que esta
           condición nunca se cumple y el bloque queda oculto. Se conserva el HTML para el futuro. *@
        @if (totalPaginas > 1)
        {
            <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2">
                <small class="text-muted">
                    Página <strong>@paginaActual</strong> de <strong>@totalPaginas</strong>
                </small>
                <nav>
                    <ul class="pagination mb-0">
                        <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-pagina="@(paginaActual - 1)">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>
                        @for (int i = 1; i <= totalPaginas; i++)
                        {
                            <li class="page-item @(i == paginaActual ? "active" : "")">
                                <a class="page-link" asp-action="Index" asp-route-pagina="@i">@i</a>
                            </li>
                        }
                        <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-pagina="@(paginaActual + 1)">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    }
</div>