@model PROmaderas.Abstracciones.Models.FacturacionAD
@{
    ViewData["Title"] = $"Factura {Model.NumeroFactura}";
}

<div class="container mt-4">
    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["Mensaje"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    @* FAC-HU-005: la factura anulada se puede abrir, pero se anuncia sin ambigüedad. *@
    @if (!Model.Activa)
    {
        var motivoAnulacion = ViewBag.MotivoAnulacion as string;
        <div class="alert alert-danger d-flex align-items-start">
            <i class="bi bi-exclamation-octagon-fill fs-4 me-2"></i>
            <div>
                <strong class="d-block fs-5">FACTURA ANULADA</strong>
                <span>Esta factura está inactiva. Se conserva como evidencia y no admite pagos.</span>
                @if (!string.IsNullOrWhiteSpace(motivoAnulacion))
                {
                    <div class="mt-1"><strong>Motivo:</strong> @motivoAnulacion</div>
                }
            </div>
        </div>
    }

    <div class="row mb-3 align-items-center">
        <div class="col"><h2>Factura <span class="text-warning">@Model.NumeroFactura</span></h2></div>
        <div class="col-auto">
            @{
                var badge = Model.Estado switch
                {
                    EstadosFactura.Pagada => "bg-success",
                    EstadosFactura.PendienteDePago => "bg-warning text-dark",
                    EstadosFactura.Anulada => "bg-secondary",
                    _ => "bg-info text-dark" // Emitida y otros
                };
            }
            <span class="badge @badge fs-6">@Model.Estado</span>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4"><div class="small text-muted">Cliente</div><strong>@Model.Cliente?.Nombre</strong><div class="small text-muted">Cédula: @Model.Cliente?.Cedula</div></div>
                <div class="col-md-4"><div class="small text-muted">Fecha de emisión</div><strong>@Model.Fecha.ToString("dd/MM/yyyy HH:mm")</strong></div>
                <div class="col-md-4"><div class="small text-muted">Orden de Compra</div><strong>@Model.Pedido?.NumeroOrden</strong></div>
            </div>
        </div>
    </div>

    @if (Model.Cliente?.Exonerado == true)
    {
        <div class="alert alert-success mb-4">
            <i class="bi bi-patch-check me-1"></i>Cliente exonerado al <strong>@Model.Cliente.PorcentajeExoneracion%</strong> — exoneración: <strong>₡@Model.Exoneracion.ToString("N2")</strong>
        </div>
    }

    @if (Model.Pedido?.Detalles != null && Model.Pedido.Detalles.Any())
    {
        <div class="card mb-4">
            <div class="card-header fw-bold" style="background-color:#c9a03c;color:#fff;"><i class="bi bi-list-ul me-1"></i>Detalle de productos</div>
            <div class="table-responsive">
                <table class="table table-bordered mb-0">
                    <thead class="table-dark">
                        <tr><th>Producto</th><th class="text-end">Precio unit.</th><th class="text-center">Cantidad</th><th class="text-end">Subtotal</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model.Pedido.Detalles)
                        {
                            <tr>
                                <td>@d.Producto?.Nombre</td>
                                <td class="text-end">₡@d.PrecioUnit.ToString("N2")</td>
                                <td class="text-center">@d.Cantidad</td>
                                <td class="text-end">₡@d.TotalLinea.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr><td colspan="3" class="text-end fw-semibold">Subtotal:</td><td class="text-end">₡@Model.Subtotal.ToString("N2")</td></tr>
                        @if (Model.Exoneracion > 0)
                        {
                            <tr class="text-success"><td colspan="3" class="text-end">Exoneración (@Model.Cliente?.PorcentajeExoneracion%):</td><td class="text-end">- ₡@Model.Exoneracion.ToString("N2")</td></tr>
                        }
                        <tr><td colspan="3" class="text-end fw-semibold">IVA (13%):</td><td class="text-end">₡@Model.Impuestos.ToString("N2")</td></tr>
                        <tr class="fw-bold" style="background-color:#c9a03c;color:#1a1a1a;"><td colspan="3" class="text-end fs-5">TOTAL:</td><td class="text-end fs-5">₡@Model.Total.ToString("N2")</td></tr>
                    </tfoot>
                </table>
            </div>
        </div>
    }

    <div class="card mb-4">
        <div class="card-header fw-bold d-flex justify-content-between align-items-center" style="background-color:#c9a03c;color:#fff;">
            <span><i class="bi bi-cash-stack me-1"></i>Historial de pagos</span>
            <span>Saldo pendiente: <strong>₡@Model.SaldoPendiente.ToString("N2")</strong></span>
        </div>
        @{
            var pagos = ViewBag.Pagos as List<PagoFacturaAD>;
        }
        @if (pagos == null || !pagos.Any())
        {
            <div class="card-body"><span class="text-muted">Sin pagos registrados.</span></div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead class="table-dark">
                        <tr><th>Fecha</th><th class="text-end">Monto</th><th>Forma de pago</th><th>Referencia</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var p in pagos)
                        {
                            <tr>
                                <td>@p.FechaPago.ToString("dd/MM/yyyy")</td>
                                <td class="text-end">₡@p.Monto.ToString("N2")</td>
                                <td>@p.FormaPago</td>
                                <td>@(string.IsNullOrWhiteSpace(p.Referencia) ? "—" : p.Referencia)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Volver al listado</a>
    @if (User.IsInRole(Roles.Administrador) || User.IsInRole(Roles.Contador))
    {
        @if (Model.Activa && Model.Estado != EstadosFactura.Pagada && Model.SaldoPendiente > 0)
        {
            <a asp-action="RegistrarPago" asp-route-id="@Model.Id" class="btn btn-success fw-bold">
                <i class="bi bi-cash-coin me-1"></i>Registrar pago
            </a>
        }
        @if (Model.Activa)
        {
            <a asp-action="CambiarEstado" asp-route-id="@Model.Id" class="btn btn-warning fw-bold">
                <i class="bi bi-arrow-repeat me-1"></i>Cambiar estado
            </a>
        }
    }
    @* FAC-HU-005: inactivar/reactivar es exclusivo del Administrador. *@
    @if (User.IsInRole(Roles.Administrador))
    {
        @if (Model.Activa)
        {
            <a asp-action="CambiarActiva" asp-route-id="@Model.Id" class="btn btn-danger fw-bold">
                <i class="bi bi-slash-circle me-1"></i>Inactivar factura
            </a>
        }
        else
        {
            <a asp-action="CambiarActiva" asp-route-id="@Model.Id" class="btn btn-success fw-bold">
                <i class="bi bi-arrow-counterclockwise me-1"></i>Reactivar factura
            </a>
        }
    }
</div>