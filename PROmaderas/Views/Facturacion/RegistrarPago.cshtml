@model PROmaderas.UI.Models.RegistrarPagoViewModel
@{
    ViewData["Title"] = "Registrar pago";
}

<div class="container mt-4" style="max-width:680px">
    <div class="row mb-3 align-items-center">
        <div class="col">
            <h2><i class="bi bi-cash-coin me-2" style="color:#c9a03c"></i>Registrar pago</h2>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <div class="small text-muted">N° Factura</div>
                    <strong style="color:#c9a03c">@Model.NumeroFactura</strong>
                </div>
                <div class="col-md-6">
                    <div class="small text-muted">Saldo pendiente</div>
                    <strong>₡@Model.SaldoPendiente.ToString("N2")</strong>
                </div>
            </div>

            <form asp-action="RegistrarPago" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="FacturaId" />
                <input type="hidden" asp-for="NumeroFactura" />
                <input type="hidden" asp-for="SaldoPendiente" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Monto</label>
                        <input asp-for="Monto" type="number" step="0.01" min="0.01" class="form-control" />
                        <span asp-validation-for="Monto" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Fecha de pago</label>
                        <input asp-for="FechaPago" type="date" class="form-control" />
                        <span asp-validation-for="FechaPago" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Forma de pago</label>
                        <select asp-for="FormaPago" class="form-select">
                            <option value="">Seleccione...</option>
                            @foreach (var fp in FormasPago.Todas)
                            {
                                <option value="@fp">@fp</option>
                            }
                        </select>
                        <span asp-validation-for="FormaPago" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Referencia <span class="text-muted fw-normal">(opcional)</span></label>
                        <input asp-for="Referencia" type="text" class="form-control" placeholder="N° transferencia, cheque..." />
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-warning fw-bold px-4">
                        <i class="bi bi-check-circle me-1"></i>Guardar
                    </button>
                    <a asp-action="Details" asp-route-id="@Model.FacturaId" class="btn btn-outline-secondary">
                        <i class="bi bi-x-lg me-1"></i>Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
