@{
    ViewData["Title"] = "Error 404 - Página No Encontrada";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="error-template">
                <h1 class="display-1 text-danger">@ViewBag.ErrorCode</h1>
                <h2 class="mb-4">@ViewBag.ErrorMessage</h2>
                <p class="lead text-muted mb-4">@ViewBag.ErrorDescription</p>
                
                <div class="error-actions">
                    <div class="row">
                        <div class="col-md-6">
                            <a asp-controller="Productos" asp-action="Index" class="btn btn-primary btn-lg">
                                <i class="bi bi-house-door"></i> Ir al Inicio
                            </a>
                        </div>
                        <div class="col-md-6">
                            <a href="javascript:history.back()" class="btn btn-secondary btn-lg">
                                <i class="bi bi-arrow-left"></i> Volver Atrás
                            </a>
                        </div>
                    </div>
                </div>

                <div class="mt-5">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">¿Necesitas ayuda?</h5>
                            <p class="card-text text-muted">
                                Si crees que esto es un error, puedes:
                            </p>
                            <ul class="list-unstyled">
                                <li><i class="bi bi-check text-success"></i> Verificar la URL en la barra de direcciones</li>
                                <li><i class="bi bi-check text-success"></i> Usar el menú de navegación para encontrar lo que buscas</li>
                                <li><i class="bi bi-check text-success"></i> Contactar al soporte técnico si el problema persiste</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .error-template {
        padding: 40px 15px;
    }
    .error-actions {
        margin-top: 15px;
        margin-bottom: 15px;
    }
    .error-actions .btn {
        margin: 5px;
    }
    .display-1 {
        font-size: 8rem;
        font-weight: 300;
        line-height: 1;
    }
</style>