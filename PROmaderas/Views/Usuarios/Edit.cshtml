@model PROmaderas.UI.Models.UsuarioEditarViewModel
@{
    ViewBag.Title = "Editar Usuario";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-person-gear me-2"></i>Editar Usuario</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
</div>

<div class="card shadow-sm" style="max-width:600px;">
    <div class="card-body">
        <form asp-action="Editar" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:none;"></div>

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" readonly />
                <small class="text-muted">El correo no se puede cambiar.</small>
            </div>

            <div class="mb-3">
                <label asp-for="Telefono" class="form-label"></label>
                <input asp-for="Telefono" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Rol" class="form-label"></label>
                <select asp-for="Rol" asp-items="ViewBag.Roles" class="form-select"></select>
                <span asp-validation-for="Rol" class="text-danger small"></span>
            </div>

            <hr />
            <p class="text-muted small"><i class="bi bi-lock me-1"></i>Deje los campos de contraseña vacíos si no desea cambiarla.</p>

            <div class="mb-3">
                <label asp-for="NuevaContrasena" class="form-label"></label>
                <input asp-for="NuevaContrasena" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="NuevaContrasena" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmarContrasena" class="form-label"></label>
                <input asp-for="ConfirmarContrasena" class="form-control" />
                <span asp-validation-for="ConfirmarContrasena" class="text-danger small"></span>
            </div>

            <div class="d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-floppy-fill me-1"></i>Guardar Cambios
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
