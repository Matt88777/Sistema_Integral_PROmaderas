@using PROmaderas.Abstracciones.Models
@model PlanillaPeriodoAD
@{
    ViewData["Title"] = "Nuevo período de planilla";
}

<div class="container mt-4">
    <h2><i class="bi bi-calendar-plus me-2" style="color:#c9a03c"></i>Nuevo período de planilla</h2>

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <form asp-action="Create" method="post" class="mt-3">
        @Html.AntiForgeryToken()

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="FechaInicio" class="form-label"></label>
                <input asp-for="FechaInicio" type="date" class="form-control" />
                <span asp-validation-for="FechaInicio" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="FechaFin" class="form-label"></label>
                <input asp-for="FechaFin" type="date" class="form-control" />
                <span asp-validation-for="FechaFin" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="TipoPeriodo" class="form-label"></label>
                <select asp-for="TipoPeriodo" class="form-select">
                    <option value="Quincenal">Quincenal</option>
                    <option value="Mensual">Mensual</option>
                    <option value="Semanal">Semanal</option>
                </select>
            </div>
        </div>

        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-warning fw-bold px-4">
                <i class="bi bi-check-circle me-1"></i>Crear período
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>