@model PROmaderas.Abstracciones.Models.PlanillaPeriodoAD
@{
    ViewData["Title"] = "Nuevo Período de Planilla";
}

<div class="container mt-4" style="max-width:600px">
    <div class="mb-3">
        <h2><i class="bi bi-journal-plus me-2" style="color:#c9a03c"></i>Nuevo Período de Planilla</h2>
    </div>

    <div class="card border-0 shadow-sm" style="background:rgba(255,255,255,0.05)">
        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="TipoPeriodo" class="form-label fw-semibold">Tipo de período</label>
                    <select asp-for="TipoPeriodo" class="form-select">
                        <option value="Quincenal">Quincenal</option>
                        <option value="Semanal">Semanal</option>
                        <option value="Mensual">Mensual</option>
                    </select>
                    <span asp-validation-for="TipoPeriodo" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="FechaInicio" class="form-label fw-semibold">Fecha de inicio</label>
                    <input asp-for="FechaInicio" type="date" class="form-control" />
                    <span asp-validation-for="FechaInicio" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="FechaFin" class="form-label fw-semibold">Fecha de fin</label>
                    <input asp-for="FechaFin" type="date" class="form-control" />
                    <span asp-validation-for="FechaFin" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-warning fw-bold px-4">
                        <i class="bi bi-check-circle me-1"></i>Crear período
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}