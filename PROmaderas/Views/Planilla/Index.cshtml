@model IEnumerable<PROmaderas.Abstracciones.Models.PlanillaAD>
@{
    ViewData["Title"] = "Planilla";
    int paginaActual = ViewBag.PaginaActual != null ? (int)ViewBag.PaginaActual : 1;
    int totalPaginas = ViewBag.TotalPaginas != null ? (int)ViewBag.TotalPaginas : 1;
}

<div class="container mt-4">
    <div class="row mb-3 align-items-center">
        <div class="col">
            <h2><i class="bi bi-cash-stack me-2" style="color:#c9a03c"></i>Planilla</h2>
        </div>
        @if (User.IsInRole("Administrador") || User.IsInRole("Contador") || User.IsInRole("Gerente"))
        {
            <div class="col-auto">
                <a asp-action="Create" class="btn btn-warning fw-bold px-4">
                    <i class="bi bi-plus-circle me-1"></i>Nuevo Registro
                </a>
            </div>
        }
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Nombre</th>
                    <th>Cédula</th>
                    <th>Puesto</th>
                    <th class="text-end">Salario Neto</th>
                    <th class="text-center" style="min-width:130px">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">@item.NombreEmpleado</td>
                        <td>@item.Cedula</td>
                        <td>@item.Puesto</td>
                        <td class="text-end">₡@item.SalarioNeto.ToString("N2")</td>
                        <td class="text-center">
                            <div class="d-flex gap-2 justify-content-center flex-nowrap">
                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-accion-ver" title="Ver detalles">
                                    <i class="bi bi-eye"></i>
                                </a>
                                @if (User.IsInRole("Administrador") || User.IsInRole("Contador"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-accion-editar" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-accion-eliminar" title="Eliminar">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            <i class="bi bi-inbox me-1"></i>No hay registros de planilla.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2">
        <small class="text-muted">
            Página <strong>@paginaActual</strong> de <strong>@totalPaginas</strong>
        </small>
        @if (totalPaginas > 1)
        {
            <nav>
                <ul class="pagination mb-0">
                    <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pagina="@(paginaActual - 1)">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    @for (int i = 1; i <= totalPaginas; i++)
                    {
                        <li class="page-item @(i == paginaActual ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-pagina="@i">@i</a>
                        </li>
                    }
                    <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pagina="@(paginaActual + 1)">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</div>