@model PROmaderas.Abstracciones.Models.PlanillaPeriodoAD
@{
    ViewData["Title"] = "Eliminar Período";
}

<div class="container mt-4" style="max-width:560px">
    <h2 class="mb-3"><i class="bi bi-trash me-2 text-danger"></i>Eliminar Período</h2>

    <div class="alert alert-danger">
        <strong>¿Está seguro que desea eliminar este período?</strong>
        Esta acción no se puede deshacer.
    </div>

    <dl class="row mb-4">
        <dt class="col-sm-4">Tipo</dt>
        <dd class="col-sm-8">@Model.TipoPeriodo</dd>

        <dt class="col-sm-4">Período</dt>
        <dd class="col-sm-8">@Model.FechaInicio.ToString("dd/MM/yyyy") — @Model.FechaFin.ToString("dd/MM/yyyy")</dd>

        <dt class="col-sm-4">Estado</dt>
        <dd class="col-sm-8">@Model.Estado</dd>
    </dl>

    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger fw-bold px-4">
                <i class="bi bi-trash me-1"></i>Sí, eliminar
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>