@using PROmaderas.Abstracciones.Models
@model PlanillaPeriodoAD
@{
    ViewData["Title"] = "Eliminar período";
}

<div class="container mt-4">
    <h2><i class="bi bi-exclamation-triangle me-2" style="color:#c9a03c"></i>Eliminar período de planilla</h2>

    <div class="card mt-3">
        <div class="card-body">
            <p>¿Confirma que desea eliminar este período y todos sus registros de horas?</p>
            <dl class="row">
                <dt class="col-sm-3">Período</dt>
                <dd class="col-sm-9">@Model.FechaInicio.ToString("dd/MM/yyyy") - @Model.FechaFin.ToString("dd/MM/yyyy")</dd>
                <dt class="col-sm-3">Tipo</dt>
                <dd class="col-sm-9">@Model.TipoPeriodo</dd>
                <dt class="col-sm-3">Empleados registrados</dt>
                <dd class="col-sm-9">@Model.CantidadEmpleados</dd>
            </dl>

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="IdPlanillaPeriodo" />
                <button type="submit" class="btn btn-accion-eliminar">
                    <i class="bi bi-trash me-1"></i>Confirmar eliminación
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </form>
        </div>
    </div>
</div>