@using PROmaderas.Abstracciones.Models
@model PlanillaPeriodoAD
@{
    ViewData["Title"] = "Detalle del período";
    var empleados = ViewBag.EmpleadosDisponibles as List<EmpleadoAD> ?? new List<EmpleadoAD>();
    var idsConHoras = Model.Detalles?.Select(d => d.IdEmpleado).ToHashSet() ?? new HashSet<int>();
    var empleadosSinRegistrar = empleados.Where(e => !idsConHoras.Contains(e.IdEmpleado ?? 0)).ToList();
    var estadoActual = Model.Estado;
}

<div class="container mt-4">
    <div class="row mb-3 align-items-center">
        <div class="col">
            <h2>
                <i class="bi bi-cash-coin me-2" style="color:#c9a03c"></i>
                Período @Model.FechaInicio.ToString("dd/MM/yyyy") - @Model.FechaFin.ToString("dd/MM/yyyy")
            </h2>
        </div>
        <div class="col-auto">
            <a asp-action="Index" class="btn btn-accion-ver">
                <i class="bi bi-arrow-left me-1"></i>Volver
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-1"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle me-1"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card text-center p-3">
                <small class="text-muted">Tipo de período</small>
                <div class="fs-5 fw-semibold text-white">@Model.TipoPeriodo</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center p-3">
                <small class="text-muted">Empleados</small>
                <div class="fs-5 fw-semibold text-white">@Model.CantidadEmpleados</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center p-3">
                <small class="text-muted">Total bruto</small>
                <div class="fs-5 fw-semibold text-white">@Model.TotalSalarioBruto.ToString("C2")</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-center p-3">
                <small class="text-muted">Estado</small>
                <div>
                    @{
                        string claseEstado = Model.Estado switch
                        {
                            "Borrador" => "badge-estado-borrador",
                            "Revisada" => "badge-estado-revisada",
                            "Aprobada" => "badge-estado-aprobada",
                            "Pagada" => "badge-estado-pagada",
                            _ => "badge-estado-borrador"
                        };
                    }
                    <span class="badge @claseEstado fs-6">@Model.Estado</span>
                </div>
            </div>
        </div>
    </div>

    @if (Model.Estado != "Pagada")
    {
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="mb-3"><i class="bi bi-clock-history me-2"></i>Registrar horas de un empleado</h5>

                @if (!empleadosSinRegistrar.Any())
                {
                    <p class="text-muted mb-0">Todos los empleados activos ya tienen horas registradas en este período.</p>
                }
                else
                {
                    <form asp-action="RegistrarHoras" method="post" class="row g-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="IdPlanillaPeriodo" value="@Model.IdPlanillaPeriodo" />

                        <div class="col-md-3">
                            <label class="form-label">Empleado</label>
                            <select name="IdEmpleado" class="form-select" required>
                                <option value="">Seleccione...</option>
                                @foreach (var emp in empleadosSinRegistrar)
                                {
                                    <option value="@emp.IdEmpleado">@emp.Nombre @emp.PrimerApellido</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Salario mensual de referencia</label>
                            <input type="number" step="0.01" min="0.01" name="SalarioMensual" class="form-control" required />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Horas ordinarias</label>
                            <input type="number" step="0.5" min="0" max="744" name="HorasOrdinarias" class="form-control" value="240" required />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Horas extra</label>
                            <input type="number" step="0.5" min="0" max="200" name="HorasExtra" class="form-control" value="0" />
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button type="submit" class="btn btn-warning fw-bold w-100">
                                <i class="bi bi-calculator me-1"></i>Calcular
                            </button>
                        </div>
                    </form>
                }
            </div>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Empleado</th>
                    <th>Horas ordinarias</th>
                    <th>Horas extra</th>
                    <th>Salario base</th>
                    <th>Monto horas extra</th>
                    <th>Salario bruto</th>
                    <th>CCSS (9.17%)</th>
                    <th>Renta</th>
                    <th>Total ded.</th>
                    <th>Salario neto</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Detalles != null)
                {
                    @foreach (var d in Model.Detalles)
                    {
                        <tr>
                            <td class="fw-semibold">@(d.Empleado != null ? $"{d.Empleado.Nombre} {d.Empleado.PrimerApellido}" : "N/D")</td>
                            <td>@d.HorasOrdinarias</td>
                            <td>@d.HorasExtra</td>
                            <td>@d.SalarioBase.ToString("C2")</td>
                            <td>@d.MontoHorasExtra.ToString("C2")</td>
                            <td class="fw-bold">@d.SalarioBruto.ToString("C2")</td>
                            <td class="text-danger">@d.DeduccionCCSS.ToString("C2")</td>
                            <td class="text-danger">@d.DeduccionRenta.ToString("C2")</td>
                            <td class="text-danger fw-semibold">@d.TotalDeducciones.ToString("C2")</td>
                            <td class="fw-bold" style="color:#c9a03c">@d.SalarioNeto.ToString("C2")</td>
                            <td class="text-center">
                                @if (Model.Estado == "Borrador")
                                {
                                    <div class="d-flex gap-2 justify-content-center">
                                        <button type="button" class="btn btn-sm btn-accion-ajustar"
                                                data-bs-toggle="modal" data-bs-target="#modalEditar@(d.IdPlanillaDetalle)"
                                                title="Editar horas">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <form asp-action="EliminarDetalle" method="post" class="d-inline m-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="idDetalle" value="@d.IdPlanillaDetalle" />
                                            <input type="hidden" name="idPeriodo" value="@Model.IdPlanillaPeriodo" />
                                            <button type="submit" class="btn btn-sm btn-accion-eliminar" title="Eliminar">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>

                                    <div class="modal fade" id="modalEditar@(d.IdPlanillaDetalle)" tabindex="-1" aria-hidden="true">
                                        <div class="modal-dialog">
                                            <div class="modal-content bg-dark text-white" style="border:1px solid #c9a03c">
                                                <form asp-action="EditarHoras" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="idPlanillaDetalle" value="@d.IdPlanillaDetalle" />
                                                    <input type="hidden" name="idPeriodo" value="@Model.IdPlanillaPeriodo" />

                                                    <div class="modal-header border-secondary">
                                                        <h5 class="modal-title">
                                                            Editar horas — @(d.Empleado != null ? $"{d.Empleado.Nombre} {d.Empleado.PrimerApellido}" : "N/D")
                                                        </h5>
                                                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                                    </div>
                                                    <div class="modal-body">
                                                        <div class="mb-3">
                                                            <label class="form-label">Salario mensual de referencia</label>
                                                            @{
                                                                var salarioRef = d.HorasOrdinarias > 0
                                                                    ? Math.Round((d.SalarioBase / d.HorasOrdinarias) * 240, 2)
                                                                    : 0;
                                                            }
                                                            <input type="number" step="0.01" min="0.01" name="salarioMensual"
                                                                   class="form-control" value="@salarioRef" required />
                                                        </div>
                                                        <div class="mb-3">
                                                            <label class="form-label">Horas ordinarias</label>
                                                            <input type="number" step="0.5" min="0" max="744" name="horasOrdinarias"
                                                                   class="form-control" value="@d.HorasOrdinarias" required />
                                                        </div>
                                                        <div class="mb-3">
                                                            <label class="form-label">Horas extra</label>
                                                            <input type="number" step="0.5" min="0" max="200" name="horasExtra"
                                                                   class="form-control" value="@d.HorasExtra" />
                                                        </div>
                                                    </div>
                                                    <div class="modal-footer border-secondary">
                                                        <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Cancelar</button>
                                                        <button type="submit" class="btn btn-warning fw-bold">
                                                            <i class="bi bi-calculator me-1"></i>Recalcular y guardar
                                                        </button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                }
                @if (Model.Detalles == null || !Model.Detalles.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            <i class="bi bi-inbox me-1"></i>Aún no hay horas registradas en este período.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>


 @* — bloque cambiar estado *@
    @if (estadoActual != "Pagada")
    {
        <div class="card mt-4">
            <div class="card-body d-flex align-items-center gap-3">
                <span class="fw-semibold">Cambiar estado del período:</span>
                <form asp-action="CambiarEstado" method="post" class="d-flex gap-2 align-items-center">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.IdPlanillaPeriodo" />
                    <select name="nuevoEstado" class="form-select form-select-sm" style="width:auto">
                        @foreach (var est in new[] { "Borrador", "Revisada", "Aprobada", "Pagada" })
                        {
                            <option value="@est" selected="@(est == estadoActual)">@est</option>
                        }
                    </select>
                    <button type="submit" class="btn btn-sm btn-warning fw-bold">
                        <i class="bi bi-arrow-repeat me-1"></i>Aplicar
                    </button>
                </form>
            </div>
        </div>
    }

</div>