@model PROmaderas.UI.Models.ReporteVentasViewModel
@using PROmaderas.Abstracciones.Catalogos

@{
    ViewData["Title"] = "Reporte de Ventas";
}

<div class="container mt-4">
    <div class="row mb-3 align-items-center">
        <div class="col">
            <h2><i class="bi bi-graph-up-arrow me-2" style="color:#c9a03c"></i>Reporte de Ventas por Período</h2>
            <p class="text-muted mb-0">Montos totales, cantidad de pedidos y estado de facturación agrupados por día, semana o mes.</p>
        </div>
        <div class="col-auto">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Volver a Reportes
            </a>
        </div>
    </div>

    <form method="get" asp-action="Ventas" class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Período</label>
                    <select name="tipoPeriodo" class="form-select">
                        <option value="@PeriodosReporteVentas.Diario" selected="@(Model.TipoPeriodo == PeriodosReporteVentas.Diario)">Diario</option>
                        <option value="@PeriodosReporteVentas.Semanal" selected="@(Model.TipoPeriodo == PeriodosReporteVentas.Semanal)">Semanal</option>
                        <option value="@PeriodosReporteVentas.Mensual" selected="@(Model.TipoPeriodo == PeriodosReporteVentas.Mensual)">Mensual</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Fecha inicio</label>
                    <input type="date" name="fechaInicio" class="form-control"
                           value="@(Model.FechaInicio?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Fecha fin</label>
                    <input type="date" name="fechaFin" class="form-control"
                           value="@(Model.FechaFin?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-auto d-flex gap-2">
                    <button type="submit" class="btn btn-warning fw-bold px-4">
                        <i class="bi bi-search me-1"></i>Generar
                    </button>
                    <a asp-action="Ventas" class="btn btn-outline-secondary">Limpiar</a>
                </div>
            </div>
            <div class="form-text mt-2">Si no indica fechas, se usa un rango por defecto según el período elegido (últimos 30 días, 12 semanas o 12 meses).</div>
        </div>
    </form>

    @if (!string.IsNullOrEmpty(Model.MensajeError))
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle me-1"></i>@Model.MensajeError
        </div>
    }
    else if (Model.ConsultaRealizada && Model.Resultado is not null)
    {
        var resultado = Model.Resultado;

        <!-- Escenario 3: sin datos -->
        @if (!resultado.HayDatos)
        {
            <div class="alert alert-warning">
                <i class="bi bi-info-circle me-1"></i>
                No hay ventas registradas para el período <strong>@resultado.TipoPeriodo</strong>
                entre el <strong>@resultado.FechaInicio.ToString("dd/MM/yyyy")</strong> y el
                <strong>@resultado.FechaFin.ToString("dd/MM/yyyy")</strong>.
            </div>
        }
        else
        {
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="card shadow-sm text-center">
                        <div class="card-body">
                            <div class="text-muted small">Pedidos en el rango</div>
                            <div class="fs-3 fw-bold">@resultado.CantidadPedidosGeneral</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card shadow-sm text-center">
                        <div class="card-body">
                            <div class="text-muted small">Monto total vendido</div>
                            <div class="fs-3 fw-bold">₡@resultado.MontoTotalGeneral.ToString("N2")</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card shadow-sm text-center">
                        <div class="card-body">
                            <div class="text-muted small">Períodos con ventas</div>
                            <div class="fs-3 fw-bold">@resultado.Periodos.Count</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-bar-chart-line me-1"></i>Detalle por período (@resultado.TipoPeriodo)</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th>Período</th>
                                    <th class="text-end">Pedidos</th>
                                    <th class="text-end">Monto Total</th>
                                    <th class="text-end">Emitidas</th>
                                    <th class="text-end">Pagadas</th>
                                    <th class="text-end">Pendientes</th>
                                    <th class="text-end">Anuladas</th>
                                    <th class="text-end">Sin facturar</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in resultado.Periodos)
                                {
                                    <tr>
                                        <td class="fw-semibold">@p.Periodo</td>
                                        <td class="text-end">@p.CantidadPedidos</td>
                                        <td class="text-end fw-bold">₡@p.MontoTotal.ToString("N2")</td>
                                        <td class="text-end"><span class="badge bg-success">@p.FacturasEmitidas</span></td>
                                        <td class="text-end"><span class="badge bg-primary">@p.FacturasPagadas</span></td>
                                        <td class="text-end"><span class="badge bg-warning text-dark">@p.FacturasPendientes</span></td>
                                        <td class="text-end"><span class="badge bg-danger">@p.FacturasAnuladas</span></td>
                                        <td class="text-end"><span class="badge bg-secondary">@p.PedidosSinFacturar</span></td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="table-dark fw-bold">
                                    <td>Total</td>
                                    <td class="text-end">@resultado.CantidadPedidosGeneral</td>
                                    <td class="text-end">₡@resultado.MontoTotalGeneral.ToString("N2")</td>
                                    <td colspan="5"></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        }

        <div class="d-flex gap-2 mb-4">
            <a class="btn btn-sm" style="background-color:#c9a03c;color:#1a1a2e;"
               asp-action="ExportarVentasExcel"
               asp-route-tipoPeriodo="@resultado.TipoPeriodo"
               asp-route-fechaInicio="@resultado.FechaInicio.ToString("yyyy-MM-dd")"
               asp-route-fechaFin="@resultado.FechaFin.ToString("yyyy-MM-dd")">
                <i class="bi bi-file-earmark-excel me-1"></i>Excel
            </a>
            <a class="btn btn-sm btn-outline-secondary"
               asp-action="ExportarVentasPdf"
               asp-route-tipoPeriodo="@resultado.TipoPeriodo"
               asp-route-fechaInicio="@resultado.FechaInicio.ToString("yyyy-MM-dd")"
               asp-route-fechaFin="@resultado.FechaFin.ToString("yyyy-MM-dd")">
                <i class="bi bi-file-earmark-pdf me-1"></i>PDF
            </a>
        </div>
    }
</div>
