@{
    ViewData["Title"] = "Reportes";
}

<div class="container mt-4">
    <h1 class="fw-bold mb-3">Reportes</h1>
    <p class="text-muted">Vista demostrativa del módulo de reportes administrativos.</p>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5>Inventario total</h5>
                    <h2 class="fw-bold">1,245</h2>
                    <p class="text-muted mb-0">Unidades registradas</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5>Facturas del mes</h5>
                    <h2 class="fw-bold">86</h2>
                    <p class="text-muted mb-0">Procesadas</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5>Clientes activos</h5>
                    <h2 class="fw-bold">34</h2>
                    <p class="text-muted mb-0">Con actividad reciente</p>
                </div>
            </div>
        </div>
    </div>
</div>