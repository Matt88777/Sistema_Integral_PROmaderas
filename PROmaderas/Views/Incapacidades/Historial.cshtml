@model List<PROmaderas.Abstracciones.Models.IncapacidadAD>

@{
    ViewData["Title"] = "Historial de incapacidades";
    string nombreEmpleado = Model.FirstOrDefault()?.Empleado is { } emp
        ? $"{emp.Nombre} {emp.PrimerApellido} {emp.SegundoApellido}".Trim()
        : "Empleado";
}

<div class="container py-4">
    <div class="d-flex align-items-center mb-4">
        <a asp-controller="Incapacidades"
           asp-action="Index"
           class="btn btn-outline-secondary me-3">
            <i class="bi bi-arrow-left"></i>
            Volver
        </a>

        <div>
            <h1 class="h3 mb-1">Historial de incapacidades</h1>
            <p class="text-muted mb-0">@nombreEmpleado</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <strong>Incapacidades registradas</strong>
            <span class="badge bg-secondary ms-2">@Model.Count</span>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Tipo</th>
                            <th>Entidad</th>
                            <th>Certificado</th>
                            <th>Fecha inicio</th>
                            <th>Fecha fin</th>
                            <th class="text-center">Días</th>
                            <th class="text-center">Estado</th>
                            <th>Observación</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.TipoIncapacidad</td>
                                <td>@item.EntidadEmisora</td>
                                <td>@item.NumeroCertificado</td>
                                <td>@item.FechaInicio.ToString("dd/MM/yyyy")</td>
                                <td>@item.FechaFin.ToString("dd/MM/yyyy")</td>
                                <td class="text-center">@item.Dias</td>
                                <td class="text-center">
                                    @if (item.Activa)
                                    {
                                        <span class="badge bg-success">Activa</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Anulada</span>
                                    }
                                </td>
                                <td>@(item.Observacion ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>