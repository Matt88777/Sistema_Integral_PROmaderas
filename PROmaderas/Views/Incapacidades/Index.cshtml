@using PROmaderas.Abstracciones.Models
@model List<IncapacidadAD>

@{
    ViewData["Title"] = "Incapacidades";
}

<div class="container py-4">
    <div class="d-flex flex-column flex-md-row
        justify-content-between align-items-md-center
        gap-3 mb-4">

        <div>
            <h1 class="h3 mb-1">Incapacidades</h1>

            <p class="text-muted mb-0">
                Registro y control de incapacidades de empleados.
            </p>
        </div>

        <a asp-controller="Incapacidades"
           asp-action="Create"
           class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>
            Registrar incapacidad
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success
            alert-dismissible fade show">
            @TempData["SuccessMessage"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger
            alert-dismissible fade show">
            @TempData["ErrorMessage"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <strong>Incapacidades registradas</strong>
        </div>

        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center p-5">
                    <i class="bi bi-calendar2-x
                        fs-1 text-muted">
                    </i>

                    <p class="text-muted mt-3 mb-0">
                        No existen incapacidades registradas.
                    </p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover
                        align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Empleado</th>
                                <th>Tipo</th>
                                <th>Inicio</th>
                                <th>Finalización</th>
                                <th>Días</th>
                                <th>Certificado</th>
                                <th>Entidad</th>
                                <th>Estado</th>
                                <th class="text-end">
                                    Acciones
                                </th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (IncapacidadAD incapacidad
                                      in Model)
                            {
                                string nombreEmpleado =
                                    string.Join(
                                        " ",
                                        new[]
                                        {
                                            incapacidad.Empleado?.Nombre,
                                            incapacidad.Empleado?.PrimerApellido,
                                            incapacidad.Empleado?.SegundoApellido
                                        }
                                        .Where(valor =>
                                            !string.IsNullOrWhiteSpace(valor)));

                                <tr>
                                    <td>
                                        <div class="fw-semibold">
                                            @nombreEmpleado
                                        </div>

                                        <small class="text-muted">
                                            @incapacidad.Empleado?.Cedula
                                        </small>
                                    </td>

                                    <td>
                                        @incapacidad.TipoIncapacidad
                                    </td>

                                    <td>
                                        @incapacidad.FechaInicio
                                        .ToString("dd/MM/yyyy")
                                    </td>

                                    <td>
                                        @incapacidad.FechaFin
                                        .ToString("dd/MM/yyyy")
                                    </td>

                                    <td>
                                        <span class="badge bg-info
                                            text-dark">
                                            @incapacidad.CantidadDias
                                        </span>
                                    </td>

                                    <td>
                                        @incapacidad.NumeroCertificado
                                    </td>

                                    <td>
                                        @incapacidad.EntidadEmisora
                                    </td>

                                    <td>
                                        @if (incapacidad.Activa)
                                        {
                                            <span class="badge bg-success">
                                                Activa
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                Anulada
                                            </span>
                                        }
                                    </td>

                                    <td class="text-end">
                                        <a asp-controller="Incapacidades"
                                           asp-action="Historial"
                                           asp-route-idEmpleado="@incapacidad.IdEmpleado"
                                           class="btn btn-sm
                                            btn-outline-info">
                                            Historial
                                        </a>

                                        @if (incapacidad.Activa)
                                        {
                                            <form asp-controller="Incapacidades"
                                                  asp-action="Anular"
                                                  method="post"
                                                  class="d-inline">

                                                @Html.AntiForgeryToken()

                                                <input type="hidden"
                                                       name="idIncapacidad"
                                                       value="@incapacidad.IdIncapacidad" />

                                                <button type="submit"
                                                        class="btn btn-sm
                                                    btn-outline-danger"
                                                        onclick="return confirm('¿Desea anular esta incapacidad?');">
                                                    Anular
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>