@model PROmaderas.UI.Services.MailMessage
@{
    ViewData["Title"] = "Vista previa del correo";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2><i class="bi bi-envelope-open me-2" style="color:#c9a03c"></i>Vista previa del correo</h2>
            <p class="text-muted mb-0">Vista previa del correo de invitacion enviado al usuario.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Inbox" class="btn btn-outline-secondary">
                <i class="bi bi-inbox me-1"></i>Bandeja de correo
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-people me-1"></i>Usuarios
            </a>
        </div>
    </div>

    <div style="background:rgba(255,255,255,0.05); border:1px solid rgba(201,168,76,0.25); border-radius:10px; padding:20px; margin-bottom:16px;">
        <div class="mb-2">
            <strong style="color:rgba(255,255,255,0.52)">Para:</strong>
            <span class="ms-2" style="color:rgba(255,255,255,0.85)">@Model.To</span>
        </div>
        <div class="mb-2">
            <strong style="color:rgba(255,255,255,0.52)">Asunto:</strong>
            <span class="ms-2" style="color:rgba(255,255,255,0.85)">@Model.Subject</span>
        </div>
        <div class="mb-3">
            <strong style="color:rgba(255,255,255,0.52)">Generado:</strong>
            <span class="ms-2" style="color:rgba(255,255,255,0.85)">@Model.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
        </div>
        <div style="background:rgba(201,168,76,0.08); border:1px solid rgba(201,168,76,0.30); border-radius:8px; padding:14px;">
            <div class="mb-2" style="color:#c9a03c; font-weight:600; font-size:13px;">
                <i class="bi bi-link-45deg me-1"></i>Link directo de activacion:
            </div>
            <a href="@Model.ActionUrl" target="_blank"
               style="color:rgba(255,255,255,0.75); font-size:13px; word-break:break-all; text-decoration:underline; text-decoration-color:rgba(255,255,255,0.30);">
                @Model.ActionUrl
            </a>
        </div>
    </div>

    <div style="border-radius:10px; overflow:hidden; border:1px solid rgba(201,168,76,0.20);">
        <div style="background:rgba(255,255,255,0.07); border-bottom:1px solid rgba(201,168,76,0.18); padding:10px 16px; display:flex; align-items:center; gap:8px;">
            <i class="bi bi-envelope-at" style="color:#c9a03c; font-size:14px;"></i>
            <span style="color:rgba(255,255,255,0.55); font-size:12px; font-weight:600; letter-spacing:0.5px; text-transform:uppercase;">Contenido del correo</span>
        </div>
        <iframe id="emailFrame"
                srcdoc="@Html.Raw(Model.HtmlBody)"
                style="width:100%; border:none; display:block; min-height:300px;"
                scrolling="no"
                onload="this.style.height = this.contentDocument.body.scrollHeight + 'px'">
        </iframe>
    </div>v>
</div>