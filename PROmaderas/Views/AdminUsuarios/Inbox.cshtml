@model IReadOnlyList<PROmaderas.UI.Services.MailMessage>
@{
    ViewData["Title"] = "Correos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2><i class="bi bi-envelope me-2" style="color:#c9a03c"></i>Correos</h2>
            <p class="text-muted mb-0">Revisa las invitaciones y enlaces de activacion enviados a los usuarios.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Volver a usuarios</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">Todavia no se han generado correos.</div>
    }
    else
    {
        <div class="d-flex flex-column gap-2">
            @foreach (var mail in Model)
            {
                <a asp-action="EmailPreview" asp-route-id="@mail.Id"
                   class="text-decoration-none"
                   style="display:block; background:rgba(255,255,255,0.05); border:1px solid rgba(201,168,76,0.25); border-radius:10px; padding:16px 20px; transition:background 0.15s, border-color 0.15s;"
                   onmouseover="this.style.background='rgba(201,168,76,0.10)';this.style.borderColor='#c9a03c'"
                   onmouseout="this.style.background='rgba(255,255,255,0.05)';this.style.borderColor='rgba(201,168,76,0.25)'">
                    <div class="d-flex w-100 justify-content-between align-items-start">
                        <h5 class="mb-1" style="color:rgba(255,255,255,0.90)">@mail.Subject</h5>
                        <small style="color:rgba(255,255,255,0.50); white-space:nowrap; margin-left:12px">
                            @mail.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        </small>
                    </div>
                    <p class="mb-1" style="color:rgba(255,255,255,0.65); font-size:14px">Para: @mail.To</p>
                    <small style="color:#c9a03c; font-size:12px">
                        <i class="bi bi-eye me-1"></i>Abrir vista previa del correo
                    </small>
                </a>
            }
        </div>
    }
</div>