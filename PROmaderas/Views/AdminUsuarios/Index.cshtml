@model IEnumerable<PROmaderas.UI.Models.AdminUserListItemViewModel>
@{
    ViewData["Title"] = "Usuarios internos";
    int paginaActual = ViewBag.PaginaActual != null ? (int)ViewBag.PaginaActual : 1;
    int totalPaginas = ViewBag.TotalPaginas != null ? (int)ViewBag.TotalPaginas : 1;
}

<div class="container mt-4">
    <div class="row mb-3 align-items-center">
        <div class="col">
            <h2><i class="bi bi-shield-lock me-2" style="color:#c9a03c"></i>Usuarios internos</h2>
            <p class="text-muted mb-0">Gestiona accesos y roles internos.</p>
        </div>
        <div class="col-auto d-flex gap-2">
            <a asp-action="Inbox" class="btn btn-outline-secondary">
                <i class="bi bi-envelope me-1"></i>Correos
            </a>
            @if (User.IsInRole("Administrador"))
            {
                <a asp-action="Create" class="btn btn-warning fw-bold px-4">
                    <i class="bi bi-person-plus me-1"></i>Registrar usuario
                </a>
            }
        </div>
    </div>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-1"></i>@TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle me-1"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Nombre</th>
                    <th>Correo</th>
                    <th>Rol</th>
                    <th>Teléfono</th>
                    <th>Estado acceso</th>
                    <th>Última invitación</th>
                    <th class="text-center" style="min-width:180px">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">@item.Nombre</td>
                        <td>@item.Email</td>
                        <td>
                            @if (item.Rol == "Administrador")
                            {
                                <span class="badge" style="background:#166534;color:#fff">Administrador</span>
                            }
                            else if (item.Rol == "Gerente")
                            {
                                <span class="badge" style="background:#1E3A8A;color:#fff">Gerente</span>
                            }
                            else if (item.Rol == "Contador")
                            {
                                <span class="badge" style="background:#164E63;color:#fff">Contador</span>
                            }
                            else if (item.Rol == "Operador de Planta")
                            {
                                <span class="badge" style="background:#5B21B6;color:#fff">Operador de Planta</span>
                            }
                            else if (item.Rol == "Vendedor")
                            {
                                <span class="badge" style="background:#92400E;color:#fff">Vendedor</span>
                            }
                            else
                            {
                                <span class="badge" style="background:#374151;color:#fff">@item.Rol</span>
                            }
                        </td>
                        <td>@(string.IsNullOrWhiteSpace(item.Telefono) ? "-" : item.Telefono)</td>
                        <td>
                            @if (item.TieneContrasena)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Pendiente</span>
                            }
                        </td>
                        <td>@(item.UltimaInvitacionUtc?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "Sin invitación")</td>
                        <td class="text-center">
                            <div class="d-flex gap-2 justify-content-center flex-nowrap">
                                <a asp-action="EditarRol" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-accion-editar" title="Modificar rol">
                                    <i class="bi bi-person-gear"></i>
                                </a>
                                @if (item.Rol != "Administrador")
                                {
                                    <form asp-action="ReenviarInvitacion" method="post" class="d-inline m-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="email" value="@item.Email" />
                                        <button type="submit" class="btn btn-sm btn-accion-ajustar"
                                                title="Reenviar invitación">
                                            <i class="bi bi-send"></i>
                                        </button>
                                    </form>
                                }
                                <a asp-action="RestablecerContrasena" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-light" title="Restablecer contraseña">
                                    <i class="bi bi-key"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            <i class="bi bi-inbox me-1"></i>No se encontraron usuarios.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2">
        <small class="text-muted">
            Página <strong>@paginaActual</strong> de <strong>@totalPaginas</strong>
        </small>
        @if (totalPaginas > 1)
        {
            <nav>
                <ul class="pagination mb-0">
                    <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-pagina="@(paginaActual - 1)">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    @for (int i = 1; i <= totalPaginas; i++)
                    {
                        <li class="page-item @(i == paginaActual ? "active" : "")">
                            <a class="page-link" asp-action="Index"
                               asp-route-pagina="@i">@i</a>
                        </li>
                    }
                    <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-pagina="@(paginaActual + 1)">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</div>