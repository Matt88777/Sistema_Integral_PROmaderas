@model IEnumerable<PROmaderas.UI.Models.AdminUserListItemViewModel>
@{
    ViewData["Title"] = "Usuarios internos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2>Usuarios internos</h2>
            <p class="text-muted mb-0">Gestiona accesos para roles internos (Gerente, Contador, Operador de Planta, Vendedor).</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Inbox" class="btn btn-outline-secondary">
                <i class="bi bi-envelope me-2"></i>Correos
            </a>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-person-plus me-2"></i>Registrar usuario interno
            </a>
        </div>
    </div>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success">@TempData["Mensaje"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Nombre</th>
                    <th>Correo</th>
                    <th>Rol</th>
                    <th>Telefono</th>
                    <th>Estado acceso</th>
                    <th>Ultima invitacion</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Nombre</td>
                        <td>@item.Email</td>
                        <td>
                            @{
                                var badgeRol = item.Rol switch
                                {
                                    "Administrador" => "bg-danger",
                                    "Gerente" => "bg-primary",
                                    "Contador" => "bg-warning text-dark",
                                    "Vendedor" => "bg-info",
                                    "Operador de Planta" => "bg-success",
                                    _ => "bg-secondary"
                                };
                            }
                            <span class="badge @badgeRol">@item.Rol</span>
                        </td>
                        <td>@(string.IsNullOrWhiteSpace(item.Telefono) ? "-" : item.Telefono)</td>
                        <td>
                            @if (item.TieneContrasena)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Pendiente</span>
                            }
                        </td>
                        <td>@(item.UltimaInvitacionUtc?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "Sin invitacion")</td>
                        <td>
                            @if (item.Rol != "Administrador")
                            {
                                <form asp-action="ReenviarInvitacion" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="email" value="@item.Email" />
                                    <button type="submit" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-send me-1"></i>Reenviar invitacion
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
