@model PROmaderas.UI.Models.AdminCreateUserViewModel
@{
    ViewData["Title"] = "Registrar usuario interno";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h2 class="mb-2">Registrar usuario interno</h2>
                    <p class="text-muted">Crea accesos para roles internos (Administrador, Gerente, Contador, Operador de Planta, Vendedor). La contrasena se define desde el correo enviado al usuario.</p>

                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Nombre" class="form-label"></label>
                            <input asp-for="Nombre" class="form-control" />
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" placeholder="ventas.nuevo@PROmaderas.local" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Telefono" class="form-label"></label>
                            <input asp-for="Telefono" class="form-control" />
                            <span asp-validation-for="Telefono" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Rol" class="form-label"></label>
                                <select asp-for="Rol" class="form-select">
                                <option value="Administrador">Administrador</option>
                                <option value="Gerente">Gerente</option>
                                <option value="Contador">Contador</option>
                                <option value="Operador de Planta">Operador de Planta</option>
                                <option value="Vendedor" selected>Vendedor</option>
                            </select>
                            <span asp-validation-for="Rol" class="text-danger"></span>
                        </div>

                        <div class="alert alert-info">
                            <i class="bi bi-envelope-paper me-2"></i>
                            Al guardar, el sistema generara un correo con el enlace para definir contrasena.
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-person-check me-2"></i>Crear usuario
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
