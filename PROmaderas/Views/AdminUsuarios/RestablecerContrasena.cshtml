@model PROmaderas.UI.Models.AdminResetPasswordViewModel
@{
    ViewData["Title"] = "Restablecer contraseña";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h2 class="mb-2">Restablecer contraseña</h2>
                    <p class="text-muted">Se restablecerá la contraseña del usuario <strong>@Model.Email</strong>.</p>

                    <form asp-action="RestablecerContrasena" method="post">
                        @Html.AntiForgeryToken()
                        <input asp-for="UserId" type="hidden" />
                        <input asp-for="Email" type="hidden" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="NuevaContrasena" class="form-label"></label>
                            <input asp-for="NuevaContrasena" class="form-control" autocomplete="new-password" />
                            <span asp-validation-for="NuevaContrasena" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmarContrasena" class="form-label"></label>
                            <input asp-for="ConfirmarContrasena" class="form-control" autocomplete="new-password" />
                            <span asp-validation-for="ConfirmarContrasena" class="text-danger"></span>
                        </div>

                        <div class="alert alert-warning">
                            <i class="bi bi-shield-lock me-2"></i>
                            La nueva contraseña queda activa de inmediato. Comunícala al usuario por un canal seguro.
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-key me-2"></i>Guardar
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
