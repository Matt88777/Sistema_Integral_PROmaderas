@model PROmaderas.UI.Models.CalcularLiquidacionViewModel
@{
    ViewData["Title"] = "Nueva liquidación";

    var empleados = (ViewBag.Empleados as List<EmpleadoAD>) ?? new List<EmpleadoAD>();
    var motivos = (ViewBag.Motivos as string[]) ?? Array.Empty<string>();
    var c = Model.Calculo;
}

<partial name="_TemaOscuro" />

<div class="container mt-4" style="max-width:900px">
    <div class="row mb-3 align-items-center">
        <div class="col">
            <h2><i class="bi bi-calculator me-2" style="color:#c9a03c"></i>Nueva liquidación</h2>
        </div>
        <div class="col-auto">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Volver
            </a>
        </div>
    </div>

    @* Escenario 3: el usuario tiene que entender ANTES de calcular por qué un motivo no le va a
       generar cesantía. Si el rubro simplemente no apareciera, no sabría si se lo comió el
       sistema o si no aplica. *@
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-1"></i>
        <strong>Qué genera cada motivo de salida:</strong>
        <ul class="mb-0 mt-2">
            <li><strong>Despido con responsabilidad</strong> — preaviso <strong>sí</strong>, cesantía <strong>sí</strong></li>
            <li><strong>Despido sin responsabilidad</strong> — preaviso <strong>no</strong>, cesantía <strong>no</strong></li>
            <li><strong>Renuncia</strong> — preaviso <strong>no</strong>, cesantía <strong>no</strong></li>
            <li><strong>Mutuo acuerdo</strong> — preaviso <strong>no</strong>, cesantía <strong>sí</strong></li>
            <li><strong>Pension</strong> — preaviso <strong>no</strong>, cesantía <strong>sí</strong></li>
        </ul>
        <div class="mt-2">
            Las <strong>vacaciones pendientes</strong> y el <strong>aguinaldo proporcional</strong>
            se pagan <strong>siempre</strong>, con cualquier motivo: son salario ya devengado.
        </div>
    </div>

    @* Los errores se pintan EXPLÍCITAMENTE desde ModelState, no con asp-validation-summary.
       El summary rendereaba una lista suelta que se perdía dentro de la tarjeta; acá el mensaje
       (p.ej. "no tiene planillas calculadas entre ... ") sale en un alert rojo que no se puede
       pasar por alto.
       <strong> y no <span>: dentro de un .alert el tema oscuro fuerza los span a blanco con
       !important y se comería el color. Mismo patrón que Views\Parametros\Index.cshtml. *@
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-octagon me-1"></i>
            <strong>No se pudo calcular la liquidación.</strong>
            <ul class="mb-0 mt-2">
                @foreach (var error in ViewData.ModelState.Values
                              .SelectMany(v => v.Errors)
                              .Where(e => !string.IsNullOrWhiteSpace(e.ErrorMessage)))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-octagon me-1"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-1"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            @* El form apunta EXPLÍCITAMENTE a Calcular. Antes era <form method="post"> a secas:
               sin atributo action, el navegador postea a la URL actual (/Liquidaciones/Create), y
               lo único que lo desviaba era el formaction del botón. Si ese formaction no se
               aplicaba, el POST caía en Create() y la pantalla se recargaba vacía, sin mensaje.
               El botón Guardar sobrescribe el destino con su propio asp-action. *@
            <form asp-controller="Liquidaciones" asp-action="Calcular" method="post">
                @Html.AntiForgeryToken()

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="IdEmpleado" class="form-label fw-semibold"></label>
                        <select asp-for="IdEmpleado" class="form-select">
                            <option value="0">-- Seleccione empleado --</option>
                            @foreach (var e in empleados)
                            {
                                var nombre = string.Join(" ", new[] { e.Nombre, e.PrimerApellido, e.SegundoApellido }
                                                                .Where(p => !string.IsNullOrWhiteSpace(p)));
                                <option value="@e.IdEmpleado">@nombre — @e.Cedula</option>
                            }
                        </select>
                        <span asp-validation-for="IdEmpleado" class="text-danger"></span>
                        <div class="form-text">Solo aparecen los empleados activos.</div>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="MotivoSalida" class="form-label fw-semibold"></label>
                        <select asp-for="MotivoSalida" class="form-select">
                            <option value="">-- Seleccione motivo --</option>
                            @foreach (var m in motivos)
                            {
                                <option value="@m">@m</option>
                            }
                        </select>
                        <span asp-validation-for="MotivoSalida" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="FechaSalida" class="form-label fw-semibold"></label>
                        <input asp-for="FechaSalida" type="date" class="form-control" />
                        <span asp-validation-for="FechaSalida" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="OtrosMontos" class="form-label fw-semibold"></label>
                        <input asp-for="OtrosMontos" type="number" step="0.01" min="0" class="form-control" />
                        <span asp-validation-for="OtrosMontos" class="text-danger"></span>
                        <div class="form-text">Rubros extra pactados. Opcional.</div>
                    </div>
                </div>

                <div class="mb-4 mt-3">
                    <label asp-for="Observacion" class="form-label fw-semibold"></label>
                    <textarea asp-for="Observacion" class="form-control" rows="2"
                              placeholder="Ej. Liquidación acordada en reunión del 10/07."></textarea>
                    <span asp-validation-for="Observacion" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" asp-action="Calcular" class="btn btn-warning fw-bold px-4">
                        <i class="bi bi-calculator me-1"></i>Calcular
                    </button>

                    @if (c != null)
                    {
                        <button type="submit" asp-action="Guardar" class="btn btn-success fw-bold px-4">
                            <i class="bi bi-floppy me-1"></i>Guardar liquidación
                        </button>
                    }
                </div>
            </form>
        </div>
    </div>

    @if (c != null)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-1"></i>
            <strong>Esto es una vista previa: todavía no se guardó nada.</strong>
            Al guardar, @c.NombreEmpleado queda <strong>inactivo</strong> con su fecha y motivo de
            salida, y los montos se <strong>congelan</strong>.
        </div>

        <partial name="_Desglose" model="c" />
    }
</div>
