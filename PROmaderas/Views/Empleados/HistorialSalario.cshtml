@using PROmaderas.Abstracciones.Models
@model List<SalarioHistorialAD>
@{
    ViewData["Title"] = "Historial salarial";
    var empleado = ViewBag.Empleado as EmpleadoAD;
}

<div class="container mt-4">
    <div class="row mb-3 align-items-center">
        <div class="col">
            <h2>
                <i class="bi bi-clock-history me-2" style="color:#c9a03c"></i>
                Historial salarial — @empleado?.Nombre @empleado?.PrimerApellido
            </h2>
        </div>
        <div class="col-auto">
            <a asp-action="Index" class="btn btn-accion-ver">
                <i class="bi bi-arrow-left me-1"></i>Volver
            </a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Fecha del cambio</th>
                    <th>Salario base</th>
                    <th>Tipo de pago</th>
                    <th>Jornada laboral</th>
                    <th>Responsable</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var h in Model)
                    {
                        <tr>
                            <td>@h.FechaCambio.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="fw-semibold" style="color:#c9a03c">
                                @(h.SalarioBase.HasValue ? h.SalarioBase.Value.ToString("C2") : "—")
                            </td>
                            <td>@(h.TipoPago ?? "—")</td>
                            <td>@(h.JornadaLaboral ?? "—")</td>
                            <td>@(h.UsuarioResponsable ?? "—")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            <i class="bi bi-inbox me-1"></i>Sin cambios salariales registrados.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>