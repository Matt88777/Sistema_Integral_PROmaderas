@using PROmaderas.Abstracciones
@model EmpleadoAD
@{
    ViewData["Title"] = "Editar Empleado";
}

<h2>Editar Empleado</h2>

@* Escenario 2: mensaje de error general (datos inválidos) *@
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
    </div>
}

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="IdEmpleado" />

    @* Resumen de errores de validación (Escenario 2) *@
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"
         style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

    <div class="mb-3">
        <label asp-for="Nombre" class="form-label"></label>
        <input asp-for="Nombre" class="form-control" />
        <span asp-validation-for="Nombre" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Cedula" class="form-label"></label>
        <input asp-for="Cedula" class="form-control" />
        <span asp-validation-for="Cedula" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="IdPuesto" class="form-label">Puesto</label>
        <select asp-for="IdPuesto" class="form-control"
                asp-items="ViewBag.PuestoSelectList as Microsoft.AspNetCore.Mvc.Rendering.SelectList">
            <option value="">-- Seleccione --</option>
        </select>
        <span asp-validation-for="IdPuesto" class="text-danger small"></span>
    </div>

    @* Los literales son EXACTAMENTE los de dbo.Departamento (sin tildes). Si una opción no
       coincide con lo que hay en la BD, el <select> no la puede marcar como seleccionada, cae
       en "-- Seleccione --" y al guardar manda "" -> el binder lo vuelve null y borra el dato.
       Antes decía IT/RRHH/Producción (con tilde): ninguno existe en la BD. *@
    <div class="mb-3">
        <label asp-for="Departamento" class="form-label"></label>
        <select asp-for="Departamento" class="form-control">
            <option value="">-- Seleccione --</option>
            <option value="Administracion">Administracion</option>
            <option value="Contabilidad">Contabilidad</option>
            <option value="Produccion">Produccion</option>
            <option value="Ventas">Ventas</option>
            <option value="Bodega">Bodega</option>
        </select>
        <span asp-validation-for="Departamento" class="text-danger small"></span>
    </div>

    @* PLA-HU-012: la fecha de ingreso define los meses trabajados, y con ellos los días de
       vacaciones acumulados. Si un empleado la tiene vacía, este es el único lugar donde se
       corrige (es adonde manda el mensaje de bloqueo de la pantalla de Vacaciones). *@
    <div class="mb-3">
        <label asp-for="FechaIngreso" class="form-label">Fecha de ingreso</label>
        <input asp-for="FechaIngreso" type="date" class="form-control" />
        <span asp-validation-for="FechaIngreso" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Telefono" class="form-label"></label>
        <input asp-for="Telefono" class="form-control" />
        <span asp-validation-for="Telefono" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Correo" class="form-label"></label>
        <input asp-for="Correo" class="form-control" type="email" />
        <span asp-validation-for="Correo" class="text-danger small"></span>
    </div>
    <hr class="my-4" />
    <h5><i class="bi bi-cash-coin me-2" style="color:#c9a03c"></i>Información salarial</h5>

    <div class="row g-3">
        <div class="col-md-4">
            <label class="form-label">Salario base</label>
            <input asp-for="SalarioBase" type="number" step="0.01" min="0" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Tipo de pago</label>
            <select asp-for="TipoPago" class="form-select">
                <option value="">Seleccione...</option>
                <option value="Mensual">Mensual</option>
                <option value="Quincenal">Quincenal</option>
                <option value="Semanal">Semanal</option>
                <option value="Por hora">Por hora</option>
            </select>
        </div>
        @* Las tres jornadas del Código de Trabajo (arts. 135-136), que es lo que guarda la BD
           ('Diurna' en los 5 empleados del seed). Antes ofrecía Tiempo completo/Medio tiempo/
           Por horas: eso son modalidades de contratación, no jornadas, y ninguna existe en la
           BD, así que el combo salía en blanco y al guardar borraba la jornada del empleado. *@
        <div class="col-md-4">
            <label class="form-label">Jornada laboral</label>
            <select asp-for="JornadaLaboral" class="form-select">
                <option value="">Seleccione...</option>
                <option value="Diurna">Diurna</option>
                <option value="Nocturna">Nocturna</option>
                <option value="Mixta">Mixta</option>
            </select>
        </div>
    </div>

    @* PLA-HU-012: hasta ahora este dato solo se podía cargar por SQL. .form-text (no <small>
       ni <span>): es la clase que el tema oscuro ya sabe tintar. *@
    <div class="row g-3 mt-1">
        <div class="col-md-4">
            <label asp-for="SaldoVacacionesInicial" class="form-label">
                Saldo de vacaciones inicial (días)
            </label>
            <input asp-for="SaldoVacacionesInicial" type="number" step="0.01" min="0"
                   class="form-control" />
            <span asp-validation-for="SaldoVacacionesInicial" class="text-danger small"></span>
            <div class="form-text">
                Días de vacaciones que el empleado ya tenía acumulados al migrarse desde Excel.
                Este valor SUMA directamente al saldo disponible. No incluye los días que acumula
                el sistema desde su fecha de ingreso.
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary">
            Guardar cambios
        </button>
        <a asp-action="Index" class="btn btn-secondary">
            Cancelar
        </a>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}