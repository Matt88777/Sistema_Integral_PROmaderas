@using PROmaderas.Abstracciones.Models
@model List<PolizaINSAD>

@{
    ViewData["Title"] = "Pólizas del INS";

    List<PolizaINSAD> proximasAVencer =
        ViewBag.PolizasProximasAVencer as List<PolizaINSAD>
        ?? new List<PolizaINSAD>();
}

<div class="container py-4">
    <div class="d-flex flex-column flex-md-row
        justify-content-between align-items-md-center
        gap-3 mb-4">

        <div>
            <h1 class="h3 mb-1">Pólizas del INS</h1>

            <p class="text-muted mb-0">
                Registro y control de las pólizas asociadas a los empleados.
            </p>
        </div>

        <a asp-controller="PolizasINS"
           asp-action="Create"
           class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>
            Registrar póliza
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show"
             role="alert">
            @TempData["SuccessMessage"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Cerrar">
            </button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show"
             role="alert">
            @TempData["ErrorMessage"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Cerrar">
            </button>
        </div>
    }

    @if (proximasAVencer.Any())
    {
        <div class="alert alert-warning mb-4">
            <div class="d-flex align-items-center mb-2">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>

                <strong>
                    Pólizas próximas a vencer
                </strong>
            </div>

            <p class="mb-2">
                Las siguientes pólizas vencen dentro de los próximos
                30 días:
            </p>

            <ul class="mb-0">
                @foreach (PolizaINSAD poliza in proximasAVencer)
                {
                    string nombreEmpleado = string.Join(
                        " ",
                        new[]
                        {
                            poliza.Empleado?.Nombre,
                            poliza.Empleado?.PrimerApellido,
                            poliza.Empleado?.SegundoApellido
                        }
                        .Where(valor =>
                            !string.IsNullOrWhiteSpace(valor)));

                    <li>
                        <strong>@nombreEmpleado</strong>:
                        póliza @poliza.NumeroPoliza,
                        vence el
                        @poliza.FechaVencimiento.ToString("dd/MM/yyyy")
                        (@poliza.DiasParaVencer día(s)).
                    </li>
                }
            </ul>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <strong>Listado de pólizas</strong>
        </div>

        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center p-5">
                    <i class="bi bi-shield-check fs-1 text-muted"></i>

                    <p class="text-muted mt-3 mb-0">
                        No existen pólizas del INS registradas.
                    </p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover
                        align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Empleado</th>
                                <th>Número</th>
                                <th>Inicio</th>
                                <th>Vencimiento</th>
                                <th>Cobertura</th>
                                <th>Estado</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (PolizaINSAD poliza in Model)
                            {
                                string nombreEmpleado = string.Join(
                                    " ",
                                    new[]
                                    {
                                        poliza.Empleado?.Nombre,
                                        poliza.Empleado?.PrimerApellido,
                                        poliza.Empleado?.SegundoApellido
                                    }
                                    .Where(valor =>
                                        !string.IsNullOrWhiteSpace(valor)));

                                bool vencida =
                                    poliza.Activa &&
                                    poliza.FechaVencimiento.Date <
                                    DateTime.Today;

                                bool proxima =
                                    poliza.Activa &&
                                    !vencida &&
                                    poliza.FechaVencimiento.Date <=
                                    DateTime.Today.AddDays(30);

                                <tr>
                                    <td>
                                        <div class="fw-semibold">
                                            @nombreEmpleado
                                        </div>

                                        <small class="text-muted">
                                            @poliza.Empleado?.Cedula
                                        </small>
                                    </td>

                                    <td>@poliza.NumeroPoliza</td>

                                    <td>
                                        @poliza.FechaInicio.ToString("dd/MM/yyyy")
                                    </td>

                                    <td>
                                        @poliza.FechaVencimiento.ToString("dd/MM/yyyy")
                                    </td>

                                    <td>@poliza.Cobertura</td>

                                    <td>
                                        @if (!poliza.Activa)
                                        {
                                            <span class="badge bg-secondary">
                                                Inactiva
                                            </span>
                                        }
                                        else if (vencida)
                                        {
                                            <span class="badge bg-danger">
                                                Vencida
                                            </span>
                                        }
                                        else if (proxima)
                                        {
                                            <span class="badge bg-warning text-dark">
                                                Próxima a vencer
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">
                                                Vigente
                                            </span>
                                        }
                                    </td>

                                    <td class="text-end">
                                        <a asp-controller="PolizasINS"
                                           asp-action="Historial"
                                           asp-route-idEmpleado="@poliza.IdEmpleado"
                                           class="btn btn-sm btn-outline-info">
                                            Historial
                                        </a>

                                        @if (poliza.Activa)
                                        {
                                            <form asp-controller="PolizasINS"
                                                  asp-action="Desactivar"
                                                  method="post"
                                                  class="d-inline">

                                                @Html.AntiForgeryToken()

                                                <input type="hidden"
                                                       name="idPolizaINS"
                                                       value="@poliza.IdPolizaINS" />

                                                <button type="submit"
                                                        class="btn btn-sm btn-outline-danger"
                                                        onclick="return confirm('¿Desea desactivar esta póliza?');">
                                                    Desactivar
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>