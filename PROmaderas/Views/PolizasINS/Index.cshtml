@using PROmaderas.Abstracciones.Models
@model List<PolizaINSAD>

@{
    ViewData["Title"] = "Pólizas del INS";

    var proximas =
        ViewBag.PolizasProximasAVencer
        as List<PolizaINSAD>
        ?? new List<PolizaINSAD>();
}

<div class="container py-4">
    <div class="d-flex flex-column flex-md-row
        justify-content-between
        align-items-md-center gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Pólizas del INS</h1>
            <p class="text-muted mb-0">
                Control de pólizas y empleados cubiertos.
            </p>
        </div>

        <a asp-action="Create"
           class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>
            Registrar póliza
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success
            alert-dismissible fade show">
            @TempData["SuccessMessage"]
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger
            alert-dismissible fade show">
            @TempData["ErrorMessage"]
            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>
        </div>
    }

    @if (proximas.Any())
    {
        <div class="alert alert-warning">
            <strong>
                <i class="bi bi-exclamation-triangle me-1"></i>
                Pólizas próximas a vencer
            </strong>

            <ul class="mb-0 mt-2">
                @foreach (var poliza in proximas)
                {
                    <li>
                        @poliza.NumeroPoliza vence el
                        @poliza.FechaVencimiento.ToString("dd/MM/yyyy")
                        (@poliza.DiasParaVencer día(s)).
                    </li>
                }
            </ul>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <strong>Listado de pólizas</strong>
        </div>

        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center p-5">
                    <p class="text-muted mb-0">
                        No existen pólizas registradas.
                    </p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover
                        align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Número</th>
                                <th>Tipo</th>
                                <th>Aseguradora</th>
                                <th>Vigencia</th>
                                <th>Empleados cubiertos</th>
                                <th>Monto asegurado</th>
                                <th>Estado</th>
                                <th class="text-end">
                                    Acciones
                                </th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var poliza in Model)
                            {
                                var asignacionesActivas =
                                    poliza.EmpleadosAsignados
                                        .Where(ep => ep.Activa)
                                        .ToList();

                                <tr>
                                    <td class="fw-semibold">
                                        @poliza.NumeroPoliza
                                    </td>

                                    <td>@poliza.TipoPoliza</td>

                                    <td>@poliza.Aseguradora</td>

                                    <td>
                                        <small class="d-block">
                                            @poliza.FechaInicio
                                            .ToString("dd/MM/yyyy")
                                        </small>
                                        <small class="d-block text-muted">
                                            hasta
                                            @poliza.FechaVencimiento
                                            .ToString("dd/MM/yyyy")
                                        </small>
                                    </td>

                                    <td>
                                        @if (!asignacionesActivas.Any())
                                        {
                                            <span class="text-muted">
                                                Sin empleados
                                            </span>
                                        }
                                        else
                                        {
                                            @foreach (var asignacion
                                                      in asignacionesActivas)
                                            {
                                                string nombre =
                                                    asignacion.Empleado == null
                                                        ? $"Empleado #{asignacion.IdEmpleado}"
                                                        : $"{asignacion.Empleado.Nombre} " +
                                                          $"{asignacion.Empleado.PrimerApellido}";

                                                <div>
                                                    <a asp-action="Historial"
                                                       asp-route-idEmpleado="@asignacion.IdEmpleado">
                                                        @nombre
                                                    </a>
                                                </div>
                                            }
                                        }
                                    </td>

                                    <td>
                                        @(poliza.MontoAsegurado.HasValue
                                            ? poliza.MontoAsegurado.Value
                                                .ToString("C2")
                                            : "No indicado")
                                    </td>

                                    <td>
                                        @if (!poliza.Estado)
                                        {
                                            <span class="badge bg-secondary">
                                                Inactiva
                                            </span>
                                        }
                                        else if (poliza.EstaVencida)
                                        {
                                            <span class="badge bg-danger">
                                                Vencida
                                            </span>
                                        }
                                        else if (poliza.ProximaAVencer)
                                        {
                                            <span class="badge
                                                bg-warning text-dark">
                                                Próxima a vencer
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">
                                                Vigente
                                            </span>
                                        }
                                    </td>

                                    <td class="text-end">
                                        @if (poliza.Estado)
                                        {
                                            <form asp-action="Desactivar"
                                                  method="post"
                                                  class="d-inline">
                                                @Html.AntiForgeryToken()

                                                <input type="hidden"
                                                       name="idPoliza"
                                                       value="@poliza.IdPoliza" />

                                                <button type="submit"
                                                        class="btn btn-sm
                                                    btn-outline-danger"
                                                        onclick="return confirm('¿Desea desactivar esta póliza?');">
                                                    Desactivar
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>