@using PROmaderas.Abstracciones.Models
@model List<PolizaINSAD>

@{
    ViewData["Title"] = "Historial de pólizas";

    PolizaINSAD? primeraPoliza = Model.FirstOrDefault();

    string nombreEmpleado = primeraPoliza == null
        ? string.Empty
        : string.Join(
            " ",
            new[]
            {
                primeraPoliza.Empleado?.Nombre,
                primeraPoliza.Empleado?.PrimerApellido,
                primeraPoliza.Empleado?.SegundoApellido
            }
            .Where(valor => !string.IsNullOrWhiteSpace(valor)));
}

<div class="container py-4">
    <div class="d-flex flex-column flex-md-row
        justify-content-between align-items-md-center
        gap-3 mb-4">

        <div>
            <h1 class="h3 mb-1">Historial de pólizas</h1>

            <p class="text-muted mb-0">
                @nombreEmpleado

                @if (!string.IsNullOrWhiteSpace(
                    primeraPoliza?.Empleado?.Cedula))
                {
                    <span>
                        - @primeraPoliza.Empleado.Cedula
                    </span>
                }
            </p>
        </div>

        <div class="d-flex gap-2">
            <a asp-controller="PolizasINS"
               asp-action="Index"
               class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>
                Volver
            </a>

            <a asp-controller="PolizasINS"
               asp-action="Create"
               class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>
                Nueva póliza
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <strong>Pólizas registradas</strong>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Número</th>
                            <th>Inicio</th>
                            <th>Vencimiento</th>
                            <th>Cobertura</th>
                            <th>Observaciones</th>
                            <th>Registro</th>
                            <th>Estado</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (PolizaINSAD poliza in Model)
                        {
                            bool vencida =
                                poliza.Activa &&
                                poliza.FechaVencimiento.Date <
                                DateTime.Today;

                            bool proximaAVencer =
                                poliza.Activa &&
                                !vencida &&
                                poliza.FechaVencimiento.Date <=
                                DateTime.Today.AddDays(30);

                            <tr>
                                <td class="fw-semibold">
                                    @poliza.NumeroPoliza
                                </td>

                                <td>
                                    @poliza.FechaInicio.ToString("dd/MM/yyyy")
                                </td>

                                <td>
                                    @poliza.FechaVencimiento.ToString("dd/MM/yyyy")
                                </td>

                                <td>
                                    @poliza.Cobertura
                                </td>

                                <td>
                                    @if (string.IsNullOrWhiteSpace(
                                        poliza.Observacion))
                                    {
                                        <span class="text-muted">
                                            Sin observaciones
                                        </span>
                                    }
                                    else
                                    {
                                        @poliza.Observacion
                                    }
                                </td>

                                <td>
                                    @poliza.FechaRegistro.ToString(
                                        "dd/MM/yyyy HH:mm")
                                </td>

                                <td>
                                    @if (!poliza.Activa)
                                    {
                                        <span class="badge bg-secondary">
                                            Inactiva
                                        </span>
                                    }
                                    else if (vencida)
                                    {
                                        <span class="badge bg-danger">
                                            Vencida
                                        </span>
                                    }
                                    else if (proximaAVencer)
                                    {
                                        <span class="badge bg-warning text-dark">
                                            Próxima a vencer
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">
                                            Vigente
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>