@using PROmaderas.Abstracciones.Models
@model List<PolizaINSAD>

@{
    ViewData["Title"] = "Historial de pólizas";
    int idEmpleado = ViewBag.IdEmpleado ?? 0;
}

<div class="container py-4">
    <div class="d-flex flex-column flex-md-row
        justify-content-between
        align-items-md-center gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">
                Historial de pólizas
            </h1>

            <p class="text-muted mb-0">
                Pólizas asignadas al empleado
                #@idEmpleado.
            </p>
        </div>

        <a asp-action="Index"
           class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>
            Volver
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <strong>Pólizas asignadas</strong>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover
                    align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Número</th>
                            <th>Tipo</th>
                            <th>Aseguradora</th>
                            <th>Inicio</th>
                            <th>Vencimiento</th>
                            <th>Monto asegurado</th>
                            <th>Prima</th>
                            <th>Estado</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var poliza in Model)
                        {
                            <tr>
                                <td class="fw-semibold">
                                    @poliza.NumeroPoliza
                                </td>

                                <td>@poliza.TipoPoliza</td>

                                <td>@poliza.Aseguradora</td>

                                <td>
                                    @poliza.FechaInicio
                                    .ToString("dd/MM/yyyy")
                                </td>

                                <td>
                                    @poliza.FechaVencimiento
                                    .ToString("dd/MM/yyyy")
                                </td>

                                <td>
                                    @(poliza.MontoAsegurado.HasValue
                                        ? poliza.MontoAsegurado.Value
                                            .ToString("C2")
                                        : "No indicado")
                                </td>

                                <td>
                                    @(poliza.Prima.HasValue
                                        ? poliza.Prima.Value
                                            .ToString("C2")
                                        : "No indicada")
                                </td>

                                <td>
                                    @if (!poliza.Estado)
                                    {
                                        <span class="badge bg-secondary">
                                            Inactiva
                                        </span>
                                    }
                                    else if (poliza.EstaVencida)
                                    {
                                        <span class="badge bg-danger">
                                            Vencida
                                        </span>
                                    }
                                    else if (poliza.ProximaAVencer)
                                    {
                                        <span class="badge
                                            bg-warning text-dark">
                                            Próxima a vencer
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">
                                            Vigente
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>