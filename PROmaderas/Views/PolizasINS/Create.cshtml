@model PROmaderas.UI.Models.RegistrarPolizaINSViewModel

@{
    ViewData["Title"] = "Registrar póliza INS";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="d-flex align-items-center mb-4">
                <a asp-action="Index"
                   class="btn btn-outline-secondary me-3">
                    <i class="bi bi-arrow-left"></i>
                    Volver
                </a>

                <div>
                    <h1 class="h3 mb-1">
                        Registrar póliza del INS
                    </h1>
                    <p class="text-muted mb-0">
                        Una póliza puede cubrir varios empleados.
                    </p>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white">
                    <strong>Información de la póliza</strong>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Create"
                          method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly"
                             class="alert alert-danger">
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="NumeroPoliza"
                                       class="form-label">
                                </label>
                                <input asp-for="NumeroPoliza"
                                       class="form-control" />
                                <span asp-validation-for="NumeroPoliza"
                                      class="text-danger">
                                </span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="TipoPoliza"
                                       class="form-label">
                                </label>
                                <select asp-for="TipoPoliza"
                                        class="form-select">
                                    <option value="Riesgos del Trabajo">
                                        Riesgos del Trabajo
                                    </option>
                                    <option value="Vida">Vida</option>
                                    <option value="Otra">Otra</option>
                                </select>
                                <span asp-validation-for="TipoPoliza"
                                      class="text-danger">
                                </span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Aseguradora"
                                   class="form-label">
                            </label>
                            <input asp-for="Aseguradora"
                                   class="form-control" />
                            <span asp-validation-for="Aseguradora"
                                  class="text-danger">
                            </span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="FechaInicio"
                                       class="form-label">
                                </label>
                                <input asp-for="FechaInicio"
                                       type="date"
                                       class="form-control" />
                                <span asp-validation-for="FechaInicio"
                                      class="text-danger">
                                </span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="FechaVencimiento"
                                       class="form-label">
                                </label>
                                <input asp-for="FechaVencimiento"
                                       type="date"
                                       class="form-control" />
                                <span asp-validation-for="FechaVencimiento"
                                      class="text-danger">
                                </span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="MontoAsegurado"
                                       class="form-label">
                                </label>
                                <input asp-for="MontoAsegurado"
                                       type="number"
                                       min="0"
                                       step="0.01"
                                       class="form-control" />
                                <span asp-validation-for="MontoAsegurado"
                                      class="text-danger">
                                </span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Prima"
                                       class="form-label">
                                </label>
                                <input asp-for="Prima"
                                       type="number"
                                       min="0"
                                       step="0.01"
                                       class="form-control" />
                                <span asp-validation-for="Prima"
                                      class="text-danger">
                                </span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="IdsEmpleados"
                                   class="form-label">
                            </label>

                            <select asp-for="IdsEmpleados"
                                    asp-items="Model.Empleados"
                                    class="form-select"
                                    multiple
                                    size="8">
                            </select>

                            <span asp-validation-for="IdsEmpleados"
                                  class="text-danger">
                            </span>

                            <div class="form-text">
                                Mantené presionada la tecla Ctrl para
                                seleccionar varios empleados.
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Observacion"
                                   class="form-label">
                            </label>
                            <textarea asp-for="Observacion"
                                      class="form-control"
                                      rows="3">
                            </textarea>
                            <span asp-validation-for="Observacion"
                                  class="text-danger">
                            </span>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index"
                               class="btn btn-outline-secondary">
                                Cancelar
                            </a>

                            <button type="submit"
                                    class="btn btn-primary">
                                <i class="bi bi-save me-1"></i>
                                Guardar póliza
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}