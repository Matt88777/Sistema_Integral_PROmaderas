@model PROmaderas.UI.Models.RegistrarPolizaINSViewModel

@{
    ViewData["Title"] = "Registrar póliza INS";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-7">
            <div class="d-flex align-items-center mb-4">
                <a asp-controller="PolizasINS"
                   asp-action="Index"
                   class="btn btn-outline-secondary me-3">
                    <i class="bi bi-arrow-left"></i>
                    Volver
                </a>

                <div>
                    <h1 class="h3 mb-1">
                        Registrar póliza del INS
                    </h1>

                    <p class="text-muted mb-0">
                        Ingrese la vigencia y cobertura de la póliza.
                    </p>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white">
                    <strong>Información de la póliza</strong>
                </div>

                <div class="card-body p-4">
                    <form asp-controller="PolizasINS"
                          asp-action="Create"
                          method="post">

                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly"
                             class="alert alert-danger"
                             role="alert">
                        </div>

                        <div class="mb-3">
                            <label asp-for="IdEmpleado"
                                   class="form-label">
                            </label>

                            <select asp-for="IdEmpleado"
                                    asp-items="Model.Empleados"
                                    class="form-select">
                                <option value="">
                                    Seleccione un empleado
                                </option>
                            </select>

                            <span asp-validation-for="IdEmpleado"
                                  class="text-danger">
                            </span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NumeroPoliza"
                                   class="form-label">
                            </label>

                            <input asp-for="NumeroPoliza"
                                   class="form-control"
                                   placeholder="Ejemplo: RT-1234567" />

                            <span asp-validation-for="NumeroPoliza"
                                  class="text-danger">
                            </span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="FechaInicio"
                                       class="form-label">
                                </label>

                                <input asp-for="FechaInicio"
                                       class="form-control"
                                       type="date" />

                                <span asp-validation-for="FechaInicio"
                                      class="text-danger">
                                </span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="FechaVencimiento"
                                       class="form-label">
                                </label>

                                <input asp-for="FechaVencimiento"
                                       class="form-control"
                                       type="date" />

                                <span asp-validation-for="FechaVencimiento"
                                      class="text-danger">
                                </span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Cobertura"
                                   class="form-label">
                            </label>

                            <textarea asp-for="Cobertura"
                                      class="form-control"
                                      rows="3"
                                      placeholder="Describa la cobertura de la póliza"></textarea>

                            <span asp-validation-for="Cobertura"
                                  class="text-danger">
                            </span>

                            <div class="form-text">
                                Máximo 250 caracteres.
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Observacion"
                                   class="form-label">
                            </label>

                            <textarea asp-for="Observacion"
                                      class="form-control"
                                      rows="3"
                                      placeholder="Información adicional opcional"></textarea>

                            <span asp-validation-for="Observacion"
                                  class="text-danger">
                            </span>

                            <div class="form-text">
                                Máximo 500 caracteres.
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-controller="PolizasINS"
                               asp-action="Index"
                               class="btn btn-outline-secondary">
                                Cancelar
                            </a>

                            <button type="submit"
                                    class="btn btn-primary">
                                <i class="bi bi-save me-1"></i>
                                Guardar póliza
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="alert alert-info mt-3 mb-0">
                <i class="bi bi-info-circle me-1"></i>

                La póliza quedará activa automáticamente después
                de guardar el registro.
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const fechaInicio =
                document.getElementById("FechaInicio");

            const fechaVencimiento =
                document.getElementById("FechaVencimiento");

            function actualizarFechaMinima() {
                if (fechaInicio.value) {
                    fechaVencimiento.min = fechaInicio.value;
                }
            }

            fechaInicio.addEventListener(
                "change",
                actualizarFechaMinima
            );

            actualizarFechaMinima();
        });
    </script>
}