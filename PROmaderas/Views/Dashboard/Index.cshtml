@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">
    <div class="dashboard-hero mb-2">
        <h1>Panel principal</h1>
        <p>Sistema Integral de Gestión Administrativa e Inventario PROMADERAS</p>
    </div>

    <div class="row g-3 dashboard-grid">

        @* Inventario *@
        @if (User.IsInRole("Administrador") || User.IsInRole("Gerente") || User.IsInRole("Operador de Planta"))
        {
            <div class="col-sm-6 col-xl-3">
                <div class="card pm-dash-card h-100">
                    <div class="card-body d-flex flex-column p-4">
                        <div class="pm-dash-icon mb-3">
                            <i class="bi bi-boxes"></i>
                        </div>
                        <h5 class="pm-dash-title">Inventario</h5>
                        <p class="pm-dash-text flex-grow-1">Control de productos, existencias y movimientos.</p>
                        <a asp-controller="Productos" asp-action="Index" class="btn btn-warning mt-3 w-100">
                            Ir a Inventario
                        </a>
                    </div>
                </div>
            </div>
        }

        @* Clientes *@
        <div class="col-sm-6 col-xl-3">
            <div class="card pm-dash-card h-100">
                <div class="card-body d-flex flex-column p-4">
                    <div class="pm-dash-icon mb-3">
                        <i class="bi bi-people"></i>
                    </div>
                    <h5 class="pm-dash-title">Clientes</h5>
                    <p class="pm-dash-text flex-grow-1">Gestión del registro y seguimiento de clientes.</p>
                    <a asp-controller="Clientes" asp-action="Index" class="btn btn-warning mt-3 w-100">
                        Ir a Clientes
                    </a>
                </div>
            </div>
        </div>

        @* Órdenes de compra *@
        <div class="col-sm-6 col-xl-3">
            <div class="card pm-dash-card h-100">
                <div class="card-body d-flex flex-column p-4">
                    <div class="pm-dash-icon mb-3">
                        <i class="bi bi-cart3"></i>
                    </div>
                    <h5 class="pm-dash-title">Órdenes de compra</h5>
                    <p class="pm-dash-text flex-grow-1">Creación y seguimiento de órdenes.</p>
                    <a asp-controller="Pedidos" asp-action="Index" class="btn btn-warning mt-3 w-100">
                        Ir a Órdenes
                    </a>
                </div>
            </div>
        </div>

        @* Usuarios *@
        @if (User.IsInRole("Administrador"))
        {
            <div class="col-sm-6 col-xl-3">
                <div class="card pm-dash-card h-100">
                    <div class="card-body d-flex flex-column p-4">
                        <div class="pm-dash-icon mb-3">
                            <i class="bi bi-shield-lock"></i>
                        </div>
                        <h5 class="pm-dash-title">Usuarios</h5>
                        <p class="pm-dash-text flex-grow-1">Administración de accesos y roles.</p>
                        <a asp-controller="AdminUsuarios" asp-action="Index" class="btn btn-warning mt-3 w-100">
                            Ir a Usuarios
                        </a>
                    </div>
                </div>
            </div>
        }

        @* Facturación *@
        @if (User.IsInRole("Administrador") || User.IsInRole("Gerente") || User.IsInRole("Contador"))
        {
            <div class="col-sm-6 col-xl-3">
                <div class="card pm-dash-card h-100">
                    <div class="card-body d-flex flex-column p-4">
                        <div class="pm-dash-icon mb-3">
                            <i class="bi bi-receipt"></i>
                        </div>
                        <h5 class="pm-dash-title">Facturación</h5>
                        <p class="pm-dash-text flex-grow-1">Consulta de facturas emitidas, pendientes y vencidas.</p>
                        <a asp-controller="Facturacion" asp-action="Index" class="btn btn-warning mt-3 w-100">
                            Ver módulo
                        </a>
                    </div>
                </div>
            </div>
        }

        @* Planilla *@
        @if (User.IsInRole("Administrador") || User.IsInRole("Gerente") || User.IsInRole("Contador"))
        {
            <div class="col-sm-6 col-xl-3">
                <div class="card pm-dash-card h-100">
                    <div class="card-body d-flex flex-column p-4">
                        <div class="pm-dash-icon mb-3">
                            <i class="bi bi-calendar2-week"></i>
                        </div>
                        <h5 class="pm-dash-title">Planilla</h5>
                        <p class="pm-dash-text flex-grow-1">Gestión de salarios, deducciones y pago semanal.</p>
                        <a asp-controller="Planilla" asp-action="Index" class="btn btn-warning mt-3 w-100">
                            Ver módulo
                        </a>
                    </div>
                </div>
            </div>
        }

        @* Reportes *@
        @if (User.IsInRole("Administrador") || User.IsInRole("Gerente"))
        {
            <div class="col-sm-6 col-xl-3">
                <div class="card pm-dash-card h-100">
                    <div class="card-body d-flex flex-column p-4">
                        <div class="pm-dash-icon mb-3">
                            <i class="bi bi-bar-chart-line"></i>
                        </div>
                        <h5 class="pm-dash-title">Reportes</h5>
                        <p class="pm-dash-text flex-grow-1">Indicadores generales y reportes administrativos.</p>
                        <a asp-controller="Reportes" asp-action="Index" class="btn btn-warning mt-3 w-100">
                            Ver módulo
                        </a>
                    </div>
                </div>
            </div>
        }

    </div>
</div>