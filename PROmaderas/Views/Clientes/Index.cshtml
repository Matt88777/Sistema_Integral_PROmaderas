@model IEnumerable<PROmaderas.Abstracciones.Models.ClienteAD>

@{
    ViewData["Title"] = "Clientes";
}

<style>
    .search-highlight {
        background-color: #fff3a3;
        color: #212529;
        padding: 0 2px;
        border-radius: 3px;
        font-weight: 600;
    }
</style>

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col">
            <h2>Gestión de Clientes</h2>
        </div>
        <div class="col text-end">
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Nuevo Cliente
            </a>
        </div>
    </div>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-6" style="position: relative;">
            <input type="text"
                   id="busquedaClientes"
                   class="form-control"
                   placeholder="Buscar por nombre, cédula, correo, teléfono o dirección..."
                   autocomplete="off" />
            <ul id="sugerenciasClientes" class="list-group mt-1" style="position:absolute; z-index:1000; display:none; max-height:200px; overflow:auto; width:100%;"></ul>
        </div>
        <div class="col-md-6">
            <button type="button" id="btnFiltrarClientes" class="btn btn-secondary">
                <i class="bi bi-search"></i> Filtrar
            </button>
            <button type="button" id="btnLimpiarClientes" class="btn btn-outline-secondary">
                Limpiar
            </button>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover" id="tablaClientes">
            <thead class="table-dark">
                <tr>
                    <th>Nombre</th>
                    <th>Cédula</th>
                    <th>Correo</th>
                    <th>Teléfono</th>
                    <th>Dirección</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="searchable">@item.Nombre</td>
                        <td class="searchable">@item.Cedula</td>
                        <td class="searchable">@item.Correo</td>
                        <td class="searchable">@(item.Telefono ?? "N/A")</td>
                        <td class="searchable">@(item.Direccion ?? "N/A")</td>
                        <td>
                            @if (item.Estado)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactivo</span>
                            }
                        </td>
                        

                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info" title="Ver detalles">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Historial" asp-route-id="@item.Id" class="btn btn-sm btn-primary" title="Historial de compras">
                                <i class="bi bi-clock-history"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Editar">
                                <i class="bi bi-pencil"></i>
                            </a>
                            @if (User.IsInRole("Administrador"))
                            {
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Eliminar">
                                    <i class="bi bi-trash"></i>
                                </a>
                            }
                            @if (User.IsInRole("Administrador") || User.IsInRole("Gerente"))
                            {
                                <form asp-action="CambiarEstado" asp-route-id="@item.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()

                                    @if (item.Estado)
                                    {
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Inactivar">
                                            <i class="bi bi-toggle-off"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn btn-sm btn-outline-success" title="Activar">
                                            <i class="bi bi-toggle-on"></i>
                                        </button>
                                    }
                                </form>
                            }
                        </td>

                    </tr>
                }

                <tr id="filaSinResultadosClientes" style="display:none;">
                    <td colspan="7" class="text-center text-muted">No se encontraron coincidencias.</td>
                </tr>
            </tbody>
        </table>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info text-center">
            No se encontraron clientes.
        </div>
    }

    @if (ViewBag.TotalPaginas > 1)
    {
        <nav aria-label="Paginación de clientes">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= ViewBag.TotalPaginas; i++)
                {
                    <li class="page-item @(i == ViewBag.PaginaActual ? "active" : "")">
                        <a class="page-link"
                               asp-action="Index"
                               asp-route-pagina="@i"
                               asp-route-filtroNombre="@ViewBag.FiltroNombre">
                            @i
                        </a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            let debounceTimer;

            function normalizarTexto(texto) {
                return (texto || '')
                    .toString()
                    .toLowerCase()
                    .normalize("NFD")
                    .replace(/[\u0300-\u036f]/g, "");
            }

            function escapeHtml(text) {
                return $('<div>').text(text || '').html();
            }

            function escapeRegex(text) {
                return (text || '').replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
            }

            function guardarTextoOriginal() {
                $('#tablaClientes tbody td.searchable').each(function () {
                    if ($(this).data('original') === undefined) {
                        $(this).data('original', $(this).text().trim());
                    }
                });
            }

            function limpiarResaltado() {
                $('#tablaClientes tbody tr').not('#filaSinResultadosClientes').each(function () {
                    $(this).find('td.searchable').each(function () {
                        const original = $(this).data('original') || '';
                        $(this).html(escapeHtml(original));
                    });
                });
            }

            function resaltarCoincidencias(textoOriginal, terminoBusqueda) {
                if (!terminoBusqueda) {
                    return escapeHtml(textoOriginal);
                }

                const texto = textoOriginal || '';
                const termino = terminoBusqueda || '';
                const regex = new RegExp('(' + escapeRegex(termino) + ')', 'ig');

                return escapeHtml(texto).replace(regex, '<span class="search-highlight">$1</span>');
            }

            function aplicarBusquedaClientes() {
                const terminoIngresado = $('#busquedaClientes').val().trim();
                const terminoNormalizado = normalizarTexto(terminoIngresado);
                let filasVisibles = 0;

                $('#tablaClientes tbody tr').not('#filaSinResultadosClientes').each(function () {
                    const fila = $(this);
                    let coincide = false;

                    fila.find('td.searchable').each(function () {
                        const textoOriginal = $(this).data('original') || '';
                        const textoNormalizado = normalizarTexto(textoOriginal);

                        if (!terminoNormalizado || textoNormalizado.includes(terminoNormalizado)) {
                            coincide = true;
                        }
                    });

                    if (coincide) {
                        fila.show();
                        filasVisibles++;

                        fila.find('td.searchable').each(function () {
                            const original = $(this).data('original') || '';

                            if (!terminoIngresado) {
                                $(this).html(escapeHtml(original));
                            } else {
                                $(this).html(resaltarCoincidencias(original, terminoIngresado));
                            }
                        });
                    } else {
                        fila.hide();
                    }
                });

                $('#filaSinResultadosClientes').toggle(filasVisibles === 0);
            }

            function mostrarSugerenciasClientes(termino) {
                var $sugerencias = $('#sugerenciasClientes');
                $sugerencias.empty();
                if (!termino || termino.length < 2) { $sugerencias.hide(); return; }

                var terminoNorm = normalizarTexto(termino);
                var nombres = [];
                $('#tablaClientes tbody tr').not('#filaSinResultadosClientes').each(function () {
                    var nombre = $(this).find('td.searchable').first().data('original') || '';
                    if (normalizarTexto(nombre).includes(terminoNorm) && nombres.indexOf(nombre) === -1) {
                        nombres.push(nombre);
                    }
                });

                if (nombres.length === 0) { $sugerencias.hide(); return; }

                nombres.slice(0, 8).forEach(function (nombre) {
                    var $li = $('<li class="list-group-item list-group-item-action" style="cursor:pointer;"></li>').text(nombre);
                    $li.on('click', function () {
                        $('#busquedaClientes').val(nombre);
                        $sugerencias.hide().empty();
                        aplicarBusquedaClientes();
                    });
                    $sugerencias.append($li);
                });
                $sugerencias.show();
            }

            guardarTextoOriginal();

            $(document).on('click', function (e) {
                if (!$(e.target).closest('#sugerenciasClientes, #busquedaClientes').length) {
                    $('#sugerenciasClientes').hide();
                }
            });

            $('#busquedaClientes').on('input', function () {
                clearTimeout(debounceTimer);
                var q = $(this).val().trim();
                mostrarSugerenciasClientes(q);
                debounceTimer = setTimeout(function () {
                    aplicarBusquedaClientes();
                }, 300);
            });

            $('#btnFiltrarClientes').on('click', function () {
                clearTimeout(debounceTimer);
                aplicarBusquedaClientes();
            });

            $('#btnLimpiarClientes').on('click', function () {
                clearTimeout(debounceTimer);
                $('#busquedaClientes').val('');
                $('#sugerenciasClientes').hide().empty();
                limpiarResaltado();
                $('#tablaClientes tbody tr').not('#filaSinResultadosClientes').show();
                $('#filaSinResultadosClientes').hide();
            });
        });
    </script>
}
