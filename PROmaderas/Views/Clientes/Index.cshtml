@model IEnumerable<PROmaderas.Abstracciones.Models.ClienteAD>
@{
    ViewData["Title"] = "Clientes";
    int paginaActual = ViewBag.PaginaActual != null ? (int)ViewBag.PaginaActual : 1;
    int totalPaginas = ViewBag.TotalPaginas != null ? (int)ViewBag.TotalPaginas : 1;
}

<div class="container mt-4">
    <div class="row mb-3 align-items-center">
        <div class="col">
            <h2><i class="bi bi-people-fill me-2" style="color:#c9a03c"></i>Gestión de Clientes</h2>
        </div>
        <div class="col-auto">
            <a asp-action="Create" class="btn btn-warning fw-bold px-4">
                <i class="bi bi-plus-circle me-1"></i>Nuevo Cliente
            </a>
        </div>
    </div>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-1"></i>@TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle me-1"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

 <form method="get" class="row g-2 mb-4">
    <div class="col-md-5" style="position:relative;">
        <input type="text" name="filtroNombre" class="form-control"
               placeholder="Buscar por nombre, cédula o correo..."
               value="@ViewBag.FiltroNombre" autocomplete="off" />
    </div>
    @{ bool? filtroEstadoVal = ViewBag.FiltroEstado as bool?; }
    <div class="col-md-3">
        <select name="filtroEstado" class="form-select">
            <option value="">Todos los estados</option>
                <option value="true" selected="@(filtroEstadoVal == true ? "selected" : null)">Activos</option>
                <option value="false" selected="@(filtroEstadoVal == false ? "selected" : null)">Inactivos</option>
            </select>
    </div>
    <div class="col-auto d-flex gap-2">
        <button type="submit" class="btn btn-secondary">
            <i class="bi bi-search me-1"></i>Buscar
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
    </div>
</form>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle" id="tablaClientes">
            <thead class="table-dark">
                <tr>
                    <th>Nombre</th>
                    <th>Cédula</th>
                    <th>Correo</th>
                    <th>Teléfono</th>
                    <th>Dirección</th>
                    <th>Estado</th>
                    <th class="text-center" style="min-width:210px">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold searchable">@item.Nombre</td>
                        <td class="searchable">@item.Cedula</td>
                        <td class="searchable">@(item.Correo ?? "N/A")</td>
                        <td class="searchable">@(item.Telefono ?? "N/A")</td>
                        <td class="searchable">@(item.Direccion ?? "N/A")</td>
                        <td>
                            <span class="badge @(item.Estado ? "bg-success" : "bg-secondary")">
                                @(item.Estado ? "Activo" : "Inactivo")
                            </span>
                        </td>
                        <td class="text-center">
                            <div class="d-flex gap-2 justify-content-center flex-nowrap">
                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-accion-ver" title="Ver detalles">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Historial" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-accion-historial" title="Historial de compras">
                                    <i class="bi bi-clock-history"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-accion-editar" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                @if (User.IsInRole("Administrador"))
                                {
                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-accion-eliminar" title="Eliminar">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                                @if (User.IsInRole("Administrador") || User.IsInRole("Gerente"))
                                {
                                    <form asp-action="CambiarEstado" asp-route-id="@item.Id"
                                          method="post" class="d-inline m-0">
                                        @Html.AntiForgeryToken()
                                        @if (item.Estado)
                                        {
                                            <button type="submit" class="btn btn-sm btn-accion-inactivar"
                                                    title="Inactivar cliente">
                                                <i class="bi bi-toggle-on"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn btn-sm btn-accion-activar"
                                                    title="Activar cliente">
                                                <i class="bi bi-toggle-off"></i>
                                            </button>
                                        }
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
                <tr id="filaSinResultadosClientes" style="display:none;">
                    <td colspan="7" class="text-center text-muted py-4">
                        <i class="bi bi-inbox me-1"></i>No se encontraron coincidencias.
                    </td>
                </tr>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            <i class="bi bi-inbox me-1"></i>No se encontraron clientes.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2">
        <small class="text-muted">
            Página <strong>@paginaActual</strong> de <strong>@totalPaginas</strong>
        </small>
        @if (totalPaginas > 1)
        {
            <nav>
                <ul class="pagination mb-0">
                    <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-pagina="@(paginaActual - 1)"
                           asp-route-filtroNombre="@ViewBag.FiltroNombre"
                           asp-route-filtroEstado="@ViewBag.FiltroEstado">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    @for (int i = 1; i <= totalPaginas; i++)
                    {
                        <li class="page-item @(i == paginaActual ? "active" : "")">
                            <a class="page-link" asp-action="Index"
                               asp-route-pagina="@i"
                               asp-route-filtroNombre="@ViewBag.FiltroNombre"
                               asp-route-filtroEstado="@ViewBag.FiltroEstado">@i</a>
                        </li>
                    }
                    <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-pagina="@(paginaActual + 1)"
                           asp-route-filtroNombre="@ViewBag.FiltroNombre"
                           asp-route-filtroEstado="@ViewBag.FiltroEstado">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            let debounceTimer;
            function normalizarTexto(t) {
                return (t||'').toString().toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g,"");
            }
            function escapeHtml(t) { return $('<div>').text(t||'').html(); }
            function escapeRegex(t) { return (t||'').replace(/[.*+?^${}()|[\]\\]/g,'\\$&'); }
            function guardarOriginal() {
                $('#tablaClientes tbody td.searchable').each(function(){
                    if($(this).data('original')===undefined) $(this).data('original',$(this).text().trim());
                });
            }
            function resaltar(orig,term) {
                if(!term) return escapeHtml(orig);
                return escapeHtml(orig).replace(new RegExp('('+escapeRegex(term)+')','ig'),
                    '<span style="background:#fff3a3;color:#212529;padding:0 2px;border-radius:3px;font-weight:600;">$1</span>');
            }
            function aplicar() {
                var ti=$('#busquedaClientes').val().trim(), tn=normalizarTexto(ti), vis=0;
                $('#tablaClientes tbody tr').not('#filaSinResultadosClientes').each(function(){
                    var fila=$(this), ok=false;
                    fila.find('td.searchable').each(function(){
                        if(!tn||normalizarTexto($(this).data('original')||'').includes(tn)) ok=true;
                    });
                    if(ok){ fila.show(); vis++;
                        fila.find('td.searchable').each(function(){
                            var o=$(this).data('original')||'';
                            $(this).html(ti?resaltar(o,ti):escapeHtml(o));
                        });
                    } else fila.hide();
                });
                $('#filaSinResultadosClientes').toggle(vis===0);
            }
            function sugerencias(term) {
                var $s=$('#sugerenciasClientes'); $s.empty();
                if(!term||term.length<2){$s.hide();return;}
                var tn=normalizarTexto(term),ns=[];
                $('#tablaClientes tbody tr').not('#filaSinResultadosClientes').each(function(){
                    var n=$(this).find('td.searchable').first().data('original')||'';
                    if(normalizarTexto(n).includes(tn)&&!ns.includes(n)) ns.push(n);
                });
                if(!ns.length){$s.hide();return;}
                ns.slice(0,8).forEach(function(n){
                    var $li=$('<li class="list-group-item list-group-item-action" style="background:#0B1B3A;color:rgba(255,255,255,0.85);border-color:rgba(201,168,76,0.15);cursor:pointer;"></li>').text(n);
                    $li.on('click',function(){$('#busquedaClientes').val(n);$s.hide().empty();aplicar();});
                    $s.append($li);
                });
                $s.show();
            }
            guardarOriginal();
            $(document).on('click',function(e){
                if(!$(e.target).closest('#sugerenciasClientes,#busquedaClientes').length) $('#sugerenciasClientes').hide();
            });
            $('#busquedaClientes').on('input',function(){
                clearTimeout(debounceTimer); sugerencias($(this).val().trim());
                debounceTimer=setTimeout(aplicar,300);
            });
            $('#btnFiltrarClientes').on('click',function(){clearTimeout(debounceTimer);aplicar();});
            $('#btnLimpiarClientes').on('click',function(){
                clearTimeout(debounceTimer);
                $('#busquedaClientes').val(''); $('#sugerenciasClientes').hide().empty();
                $('#tablaClientes tbody td.searchable').each(function(){$(this).html(escapeHtml($(this).data('original')||''));});
                $('#tablaClientes tbody tr').not('#filaSinResultadosClientes').show();
                $('#filaSinResultadosClientes').hide();
            });
        });
    </script>
}