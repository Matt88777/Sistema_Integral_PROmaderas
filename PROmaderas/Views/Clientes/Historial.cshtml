@model PROmaderas.UI.Models.ClienteHistorialViewModel
@{
    ViewData["Title"] = "Historial de Compras";
}

<div class="container mt-4">

    @* Encabezado con datos del cliente *@
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2>Historial de Compras</h2>
            <p class="text-muted mb-0">
                <strong>@Model.Cliente.Nombre</strong> &mdash;
                Cédula: @Model.Cliente.Cedula &mdash;
                @Model.Cliente.Correo
            </p>
        </div>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Volver al listado
        </a>
    </div>

    @* Escenario 1 y 3: resumen general si tiene historial *@
    @if (Model.TieneHistorial)
    {
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card text-bg-primary">
                    <div class="card-body">
                        <h6 class="card-title">Total de órdenes</h6>
                        <h3 class="mb-0">@Model.TotalOrdenes</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-bg-success">
                    <div class="card-body">
                        <h6 class="card-title">Monto total comprado</h6>
                        <h3 class="mb-0">₡@Model.TotalCompras.ToString("N2")</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-bg-info">
                    <div class="card-body">
                        <h6 class="card-title">Última compra</h6>
                        <h3 class="mb-0">@Model.Pedidos.First().Fecha.ToString("dd/MM/yyyy")</h3>
                    </div>
                </div>
            </div>
        </div>

        @* Escenario 3: detalle de cada orden *@
        @foreach (var pedido in Model.Pedidos)
        {
            <div class="card mb-4 shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div>
                        <strong>Orden #@pedido.NumeroOrden</strong>
                        <span class="ms-3 text-muted">
                            <i class="bi bi-calendar3"></i>
                            @pedido.Fecha.ToString("dd/MM/yyyy HH:mm")
                        </span>
                    </div>
                    <span class="badge @(pedido.Estado == "Completado" ? "bg-success" :
                                                                   pedido.Estado == "Pendiente" ? "bg-warning text-dark" :
                                                                   pedido.Estado == "Cancelado" ? "bg-danger" : "bg-secondary")">
                        @pedido.Estado
                    </span>
                </div>

                <div class="card-body">

                    @* Escenario 3: líneas de productos *@
                    @if (pedido.Detalles.Any())
                    {
                        <table class="table table-sm table-bordered mb-3">
                            <thead class="table-light">
                                <tr>
                                    <th>Producto</th>
                                    <th class="text-end">Cant.</th>
                                    <th class="text-end">Precio Unit.</th>
                                    <th class="text-end">Descuento</th>
                                    <th class="text-end">Imp. %</th>
                                    <th class="text-end">Total Línea</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var detalle in pedido.Detalles)
                                {
                                    <tr>
                                        <td>@(detalle.Producto?.Nombre ?? $"Producto #{detalle.ProductoId}")</td>
                                        <td class="text-end">@detalle.Cantidad</td>
                                        <td class="text-end">₡@detalle.PrecioUnit.ToString("N2")</td>
                                        <td class="text-end">₡@detalle.Descuento.ToString("N2")</td>
                                        <td class="text-end">@detalle.ImpuestoPorc %</td>
                                        <td class="text-end">₡@detalle.TotalLinea.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }

                    @* Escenario 3: montos de la orden *@
                    <div class="row justify-content-end">
                        <div class="col-md-4">
                            <table class="table table-sm">
                                <tr>
                                    <td>Subtotal</td>
                                    <td class="text-end">₡@pedido.Subtotal.ToString("N2")</td>
                                </tr>
                                <tr>
                                    <td>Impuestos</td>
                                    <td class="text-end">₡@pedido.Impuestos.ToString("N2")</td>
                                </tr>
                                <tr class="fw-bold">
                                    <td>Total</td>
                                    <td class="text-end">₡@pedido.Total.ToString("N2")</td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(pedido.Observacion))
                    {
                        <p class="text-muted mb-0">
                            <i class="bi bi-chat-left-text"></i>
                            <em>@pedido.Observacion</em>
                        </p>
                    }
                </div>
            </div>
        }
    }
    else
    {
        @* Escenario 2: cliente sin historial *@
        <div class="alert alert-info d-flex align-items-center gap-3 mt-4" role="alert">
            <i class="bi bi-info-circle-fill fs-4"></i>
            <div>
                El cliente <strong>@Model.Cliente.Nombre</strong> no tiene órdenes de compra registradas.
            </div>
        </div>
    }

</div>