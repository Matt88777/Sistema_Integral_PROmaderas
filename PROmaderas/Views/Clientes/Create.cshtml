@model PROmaderas.Abstracciones.Models.ClienteAD

@{
    ViewData["Title"] = "Crear Cliente";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h2>Crear Nuevo Cliente</h2>
            <hr />

            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                @* Datos Generales *@
                <h5 class="mt-3 mb-3 text-secondary">Datos Generales</h5>

                <div class="mb-3">
                    <label asp-for="Nombre" class="form-label fw-semibold"></label>
                    <input asp-for="Nombre" class="form-control" placeholder="Nombre completo o razón social" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Cedula" class="form-label fw-semibold"></label>
                        <input asp-for="Cedula" class="form-control" placeholder="Ej: 3101234567" />
                        <span asp-validation-for="Cedula" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Telefono" class="form-label fw-semibold"></label>
                        <input asp-for="Telefono" class="form-control" placeholder="Ej: 22001234" />
                        <span asp-validation-for="Telefono" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Correo" class="form-label fw-semibold"></label>
                    <input asp-for="Correo" class="form-control" type="email" placeholder="correo@empresa.com" />
                    <span asp-validation-for="Correo" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Direccion" class="form-label fw-semibold"></label>
                    <textarea asp-for="Direccion" class="form-control" rows="3" placeholder="Dirección completa"></textarea>
                    <span asp-validation-for="Direccion" class="text-danger"></span>
                </div>

                @* Condiciones de Pago *@
                <h5 class="mt-4 mb-3 text-secondary">Condiciones de Pago</h5>

                <div class="mb-3">
                    <label asp-for="CondicionPago" class="form-label fw-semibold"></label>
                    <select asp-for="CondicionPago" class="form-select">
                        <option value="Contado">Contado</option>
                        <option value="Crédito 15 días">Crédito 15 días</option>
                        <option value="Crédito 30 días">Crédito 30 días</option>
                        <option value="Crédito 60 días">Crédito 60 días</option>
                        <option value="Crédito 90 días">Crédito 90 días</option>
                    </select>
                    <span asp-validation-for="CondicionPago" class="text-danger"></span>
                </div>

                @* Exoneraciones Fiscales *@
                <h5 class="mt-4 mb-3 text-secondary">Exoneración Fiscal</h5>

                <div class="mb-3">
                    <div class="form-check form-switch">
                        <input asp-for="Exonerado" class="form-check-input" id="switchExonerado" />
                        <label class="form-check-label" for="switchExonerado">Cliente exonerado de impuestos</label>
                    </div>
                </div>

                <div class="mb-3" id="campoExoneracion" style="display:none;">
                    <label asp-for="PorcentajeExoneracion" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <input asp-for="PorcentajeExoneracion" class="form-control" type="number" min="0" max="100" step="0.01" />
                        <span class="input-group-text">%</span>
                    </div>
                    <span asp-validation-for="PorcentajeExoneracion" class="text-danger"></span>
                </div>

                <div class="mt-4">
                    <input type="submit" value="Crear Cliente" class="btn btn-primary" />
                    <a asp-action="Index" class="btn btn-secondary">Volver al listado</a>
                </div>
            </form>

            @section Scripts {
                @{
                    await Html.RenderPartialAsync("_ValidationScriptsPartial");
                }
                <script>
                                const switchExonerado = document.getElementById('switchExonerado');
                                const campoExoneracion = document.getElementById('campoExoneracion');

                                // Mostrar/ocultar campo de porcentaje según el switch
                                switchExonerado.addEventListener('change', function () {
                                    campoExoneracion.style.display = this.checked ? 'block' : 'none';
                                    if (!this.checked) {
                                        document.getElementById('PorcentajeExoneracion').value = '0';
                                    }
                                });

                                // Estado inicial
                                campoExoneracion.style.display = switchExonerado.checked ? 'block' : 'none';
                </script>
            }
        </div>
    </div>
</div>