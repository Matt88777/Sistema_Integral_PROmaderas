@model List<PROmaderas.Abstracciones.Models.LicenciaAD>

@{
	ViewData["Title"] = "Licencias";
}

<div class="d-flex justify-content-between align-items-center mb-3">
	<h2 class="text-white">Licencias Especiales</h2>
	<a asp-action="Create" class="btn" style="background-color:#c9a03c;color:#1a1a1a;">
		<i class="bi bi-plus-lg"></i> Nueva Licencia
	</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
	<div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
	<div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="table-responsive">
	<table class="table table-dark table-hover align-middle">
		<thead>
			<tr>
				<th>Empleado</th>
				<th>Tipo</th>
				<th>Fecha Inicio</th>
				<th>Fecha Fin</th>
				<th>Días</th>
				<th>Con Goce Salarial</th>
				<th>Observación</th>
				<th class="text-end">Acciones</th>
			</tr>
		</thead>
		<tbody>
			@foreach (var licencia in Model)
			{
				<tr>
					<td>@licencia.Empleado?.Nombre</td>
					<td>@licencia.TipoLicencia</td>
					<td>@licencia.FechaInicio.ToString("dd/MM/yyyy")</td>
					<td>@licencia.FechaFin.ToString("dd/MM/yyyy")</td>
					<td>@licencia.Dias</td>
					<td>
						@if (licencia.ConGoceSalarial)
						{
							<span class="badge" style="background-color:#c9a03c;color:#1a1a1a;">Sí</span>
						}
						else
						{
							<span class="badge bg-secondary">No</span>
						}
					</td>
					<td>@licencia.Observacion</td>
					<td class="text-end">
						<a asp-action="Edit" asp-route-id="@licencia.IdLicencia" class="btn btn-sm btn-outline-warning">Editar</a>
						<a asp-action="Delete" asp-route-id="@licencia.IdLicencia" class="btn btn-sm btn-outline-danger">Eliminar</a>
					</td>
				</tr>
			}
		</tbody>
	</table>
</div>